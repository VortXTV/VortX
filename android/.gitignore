# Local Gradle cache/config (per-machine; regenerated by the wrapper). NOT the wrapper jar itself
# (gradle/wrapper/gradle-wrapper.jar IS tracked, this is Gradle's scratch dir under android/.gradle/).
.gradle/

# Per-machine Android SDK path; CI sets this via android-actions/setup-android, never commit a local one.
local.properties

# Android Studio / IntelliJ project files (regenerated).
.idea/
*.iml

# cargo-ndk output (android/app/build.gradle.kts writes it under build/, already covered by the root
# **/build/ glob, but the jniLibs staging dir name is called out here for clarity).
captures/

# Kotlin compiler scratch/cache dir (regenerated per build; never committed).
.kotlin/

# Prebuilt vortx-core JNI cdylib (libvortx_ffi.so), produced OUT-OF-REPO from the engine branch's
# vortx-core (crates/ffi with --no-default-features --features jni) via cargo-ndk; see
# app/src/main/jniLibs/README.md for the exact command. Binaries are never committed; every
# machine/CI builds its own. The README itself stays tracked.
app/src/main/jniLibs/**/*.so
