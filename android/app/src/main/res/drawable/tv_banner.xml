<?xml version="1.0" encoding="utf-8"?>
<!--
  Android TV launcher banner (S13). Leanback/Google TV shows this tile for the app on the home row, so a
  TV build MUST declare `android:banner` (the MissingTvBanner lint this catalog previously suppressed with
  a "scheduled for S13" note; that note is now retired in app/build.gradle.kts). The documented banner
  metric is 320x180 xhdpi; a vector renders crisp at any density, so this is a 320x180-viewport vector
  rather than a raster set.

  Brand: the same warm radial obsidian (#18130C -> #0C0A07) as the adaptive-icon background + splash
  (res/drawable/ic_launcher_background.xml, DESIGN-SYSTEM.md §2 "Splash"), with the VortX woven-X mark
  (the exact ribbon geometry from ic_vortx_mark.xml, DESIGN-SYSTEM.md §2 "The mark") scaled up and
  centered via a group transform. Fixed brand gold-on-obsidian, never the live accent: the icon,
  splash, and banner keep the fixed brand mark (same rule colors.xml documents for vortx_canvas).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Warm obsidian radial background, full bleed. -->
    <path android:pathData="M0,0h320v180h-320z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="160"
                android:centerY="90"
                android:gradientRadius="200"
                android:startColor="#18130C"
                android:endColor="#0C0A07" />
        </aapt:attr>
    </path>

    <!-- The VortX mark, centered. The three paths are the 108-viewport mark from ic_vortx_mark.xml; the
         group scales them ~1.28x and translates so the 108-box centers in the 320x180 banner
         (translateX = (320 - 108*1.28)/2 ≈ 90.9, translateY = (180 - 108*1.28)/2 ≈ 20.9). -->
    <group
        android:scaleX="1.28"
        android:scaleY="1.28"
        android:translateX="90.9"
        android:translateY="20.9">

        <!-- Back ribbon: the "\" diagonal, drawn first so the front ribbon crosses over it. -->
        <path
            android:pathData="M29.9,28.2 C49.0,42.4 56.5,65.6 75.6,79.8"
            android:strokeLineCap="round"
            android:strokeWidth="12.5"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="52.7" android:startY="20"
                    android:endX="52.7" android:endY="88"
                    android:startColor="#B45309"
                    android:endColor="#7C2D12" />
            </aapt:attr>
        </path>

        <!-- Front ribbon: the "/" diagonal, drawn second so it crosses over the back ribbon. -->
        <path
            android:pathData="M75.6,28.2 C56.5,42.4 49.0,65.6 29.9,79.8"
            android:strokeLineCap="round"
            android:strokeWidth="12.5"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="52.7" android:startY="20"
                    android:endX="52.7" android:endY="88"
                    android:startColor="#FBBF24"
                    android:centerColor="#F59E0B"
                    android:centerX="0.55"
                    android:endColor="#D97706" />
            </aapt:attr>
        </path>

        <!-- Cream center dot. -->
        <path
            android:pathData="M52.7,49.4 a4.6,4.6 0,1,1 0,9.2 a4.6,4.6 0,1,1 0,-9.2 z"
            android:fillColor="#FDF6E3" />
    </group>
</vector>
