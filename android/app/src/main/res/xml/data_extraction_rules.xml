<?xml version="1.0" encoding="utf-8"?>
<!--
  API 31+ backup / device-transfer rules. The Android analogue of the Apple store's `isExcludedFromBackup`
  resource value on its Downloads directory (app/SourcesShared/DownloadStore.swift).

  Both destinations exclude the same paths, for the same reason and with an extra one for transfer:
    - cloud-backup:   downloaded media is large and re-downloadable; it has no business consuming the user's
                      cloud backup quota.
    - device-transfer: the media is a physical file on ONE device. Carrying index.json to a new device would
                      list downloads whose bytes never made the trip, which is exactly the "syncing the LIST
                      to a device that lacks the file is misleading" rule the store's own doc comment states.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="Downloads" />
        <exclude domain="sharedpref" path="vortx.downloads.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="Downloads" />
        <exclude domain="sharedpref" path="vortx.downloads.xml" />
    </device-transfer>
</data-extraction-rules>
