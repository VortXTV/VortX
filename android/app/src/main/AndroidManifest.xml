<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Offline downloads (Round 5). A multi-GB media transfer must run as a foreground service or the OS
         suspends it the moment the app leaves the screen; this is the Android cost of what Apple gets from a
         `.background` URLSession for free.
           - FOREGROUND_SERVICE:           the base permission (API 28+).
           - FOREGROUND_SERVICE_DATA_SYNC: required from API 34 for the `dataSync` service type, which is the
                                           documented type for a user-initiated file transfer.
           - POST_NOTIFICATIONS:           required from API 33 to SHOW the progress notification. It is a runtime
                                           permission; if the user denies it the foreground service still runs and
                                           the download still completes, the progress notification just isn't
                                           displayed. Downloads therefore never gate on it. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Wakes DownloadUnlockReceiver so a download parked by a locked-write failure recovers after a reboot,
         instead of dead-ending at "couldn't save" (#132). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Android TV: declare leanback so the app shows on the TV launcher, but don't require it
         so phones/tablets install too. -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:name=".VortXApplication"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:banner="@drawable/tv_banner"
        android:localeConfig="@xml/locales_config"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.VortX"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules">

        <!-- PHONE / touch entry. MainActivity keeps the ordinary MAIN + LAUNCHER filter (the touch shell,
             com.vortx.android.ui.StremioXApp). It NO LONGER carries LEANBACK_LAUNCHER: the 10-foot D-pad
             surface is a distinct activity (TvActivity, below) so the two entrypoints can diverge in
             layout/focus while sharing one process, one repository, and the same ViewModels. On a phone
             only LAUNCHER activities appear; on a TV only LEANBACK_LAUNCHER ones do, so a single APK still
             serves both form factors (the uses-feature leanback/touchscreen required=false above is what
             lets that one APK install on each). -->
        <!-- Picture-in-Picture (player). The player is a composable inside this activity, so the PiP
             declaration lives here: supportsPictureInPicture is what makes setPictureInPictureParams /
             enterPictureInPictureMode legal, and resizeableActivity is declared explicitly (not left to
             the targetSdk default) because PiP is a resize. The player composition alone arms PiP
             (auto-enter on S+, onUserLeaveHint below it) and revokes it when it leaves composition, so a
             Home press on the browse shell never PiPs the app. configChanges adds
             smallestScreenSize|screenLayout: the fullscreen-to-PiP transition changes BOTH, and without
             them the activity (and the live player engine in it) would be recreated at the exact moment
             the video should keep rolling seamlessly. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.VortX.Splash"
            android:supportsPictureInPicture="true"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ANDROID TV / 10-foot entry (S13). The LEANBACK_LAUNCHER category is what the TV launcher lists;
             this activity lands on the D-pad browse shell (com.vortx.android.ui.tv.TvApp). It reuses the
             SAME VortXApplication-owned repository + the SAME HomeViewModel / DetailViewModel as the phone
             shell (via StremioXViewModelFactory) and hands playback to the SAME PlayerScreen, with no
             forked business logic and no parallel data path; only the presentation layer differs. The
             `android:banner`
             is inherited from <application>; it is repeated here so the launcher tile resolves even on
             launchers that read the per-activity banner first. Same splash theme + configChanges as
             MainActivity so a TV cold start shows the identical brand splash. -->
        <!-- Same PiP declaration as MainActivity: the TV shell hands playback to the same PlayerScreen,
             and Android TV supports PiP (auto-enter on S+ TVs; older TVs and the pre-S Home press fall
             back to the in-player PiP control, since only MainActivity carries the onUserLeaveHint
             override). Harmless where the launcher/device lacks the PiP feature: the player probes the
             system feature + this flag at runtime and stands down. -->
        <activity
            android:name=".ui.tv.TvActivity"
            android:exported="true"
            android:banner="@drawable/tv_banner"
            android:theme="@style/Theme.VortX.Splash"
            android:supportsPictureInPicture="true"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Declare the foreground-service TYPE on WorkManager's own service. From API 34 a foreground service
             must declare its type BOTH here and in the ForegroundInfo the worker returns, and the two must
             agree, or startForeground throws at runtime. The WorkManager artifact ships this component with no
             type, so the type is merged onto it here rather than redeclared. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- #132 auto-recovery: resume a download parked by a locked-write failure once the user unlocks.
             MANIFEST-registered, not runtime-registered, precisely because the app process is usually gone by
             then; a runtime receiver would miss the exact case it exists for. Not exported: both actions are
             protected system broadcasts, so no other app can drive it. Not directBootAware: it has nothing to
             do until credential-encrypted storage is readable, which is the very condition it waits for. -->
        <receiver
            android:name=".downloads.DownloadUnlockReceiver"
            android:exported="false"
            android:directBootAware="false">
            <intent-filter>
                <action android:name="android.intent.action.USER_UNLOCKED" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
