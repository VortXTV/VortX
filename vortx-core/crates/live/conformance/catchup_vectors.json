{
  "description": "Cross-language conformance for the LT-CATCHUP URL template engine. Times derive from the LT2 UTC-ms window: unix seconds via integer floor-division; the broken-out {Y}{m}{d}{H}{M}{S} fields are the Hinnant inverse of LT2 days_from_civil (same 1970-01-01 epoch, no float). All cases use start=1782741600000ms (2026-06-29 14:00:00 UTC), stop=1782745200000ms (+1h), now=1782745800000ms (+1h10m), so utc=1782741600, utcend=1782745200, lutc=1782745800, duration=3600, offset=4200. Placeholders accept {name} and ${name}; unknown placeholders are left intact. A port must reproduce every URL byte-for-byte.",
  "start_utc_ms": 1782741600000,
  "stop_utc_ms": 1782745200000,
  "now_ms": 1782745800000,
  "render": [
    { "name": "unix_seconds_family", "template": "p?utc={utc}&end={utcend}&now={lutc}&dur={duration}&off={offset}", "expect": "p?utc=1782741600&end=1782745200&now=1782745800&dur=3600&off=4200" },
    { "name": "dollar_brace_form", "template": "p?s=${start}&e=${end}", "expect": "p?s=1782741600&e=1782745200" },
    { "name": "broken_out_civil_fields", "template": "{Y}-{m}-{d}:{H}-{M}-{S}", "expect": "2026-06-29:14-00-00" },
    { "name": "unknown_placeholder_left_intact", "template": "a={utc}&b={mystery}", "expect": "a=1782741600&b={mystery}" }
  ],
  "entry": [
    {
      "name": "catchup_source_template",
      "attributes": [["catchup", "default"], ["catchup-source", "http://h/play?utc={utc}&dur={duration}"]],
      "url": "http://h/live.ts",
      "expect": "http://h/play?utc=1782741600&dur=3600"
    },
    {
      "name": "catchup_type_appends_query_no_existing_qs",
      "attributes": [["catchup", "default"]],
      "url": "http://h/live.ts",
      "expect": "http://h/live.ts?utc=1782741600&lutc=1782745800"
    },
    {
      "name": "catchup_type_appends_query_with_existing_qs",
      "attributes": [["catchup", "append"]],
      "url": "http://h/live.ts?token=x",
      "expect": "http://h/live.ts?token=x&utc=1782741600&lutc=1782745800"
    },
    {
      "name": "no_catchup_is_none",
      "attributes": [["tvg-id", "cnn"]],
      "url": "http://h/live.ts",
      "expect": null
    },
    {
      "name": "disabled_catchup_is_none",
      "attributes": [["catchup", "none"]],
      "url": "http://h/live.ts",
      "expect": null
    }
  ]
}
