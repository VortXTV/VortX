{
  "description": "Cross-language conformance for LT-BIND: epg_channel_id_for(channel, epg_channels) reconciles an LT3 ChannelModel (channel_id = t:<tvg-id> | c:<hash> | u:<hash>) to a raw LT2 EPG channel id (as Program.channel_id uses). Fallback chain: tvg-id exact (case-insensitive, via the LT3 norm_tvg) -> normalized display name (via the LT3 normalize_name, empty never matches) -> none. On duplicate EPG ids the lexicographically smallest raw id is chosen (order-independent). A port must reproduce every binding byte-for-byte.",
  "cases": [
    {
      "name": "tvg_id_exact_case_insensitive_returns_raw_epg_id",
      "channel": { "channel_id": "t:cnn.us", "display_name": "CNN HD", "feeds": [] },
      "epg_channels": [
        { "id": "CNN.us", "display_names": ["CNN"] },
        { "id": "bbc.uk", "display_names": ["BBC"] }
      ],
      "expect": "CNN.us"
    },
    {
      "name": "name_only_channel_binds_by_normalized_display_name",
      "channel": { "channel_id": "c:5a9f217db9f2b8b7", "display_name": "CNN HD", "feeds": [] },
      "epg_channels": [ { "id": "cnn.us", "display_names": ["CNN HD"] } ],
      "expect": "cnn.us"
    },
    {
      "name": "tvg_channel_falls_back_to_name_when_tvg_absent",
      "channel": { "channel_id": "t:cnn.us", "display_name": "CNN", "feeds": [] },
      "epg_channels": [ { "id": "other.id", "display_names": ["CNN"] } ],
      "expect": "other.id"
    },
    {
      "name": "no_match_is_none",
      "channel": { "channel_id": "t:cnn.us", "display_name": "CNN", "feeds": [] },
      "epg_channels": [ { "id": "espn.us", "display_names": ["ESPN"] } ],
      "expect": null
    },
    {
      "name": "empty_normalized_name_never_matches",
      "channel": { "channel_id": "u:deadbeef", "display_name": "***", "feeds": [] },
      "epg_channels": [ { "id": "x", "display_names": ["!!!"] } ],
      "expect": null
    },
    {
      "name": "duplicate_epg_ids_pick_the_smallest",
      "channel": { "channel_id": "t:cnn.us", "display_name": "CNN", "feeds": [] },
      "epg_channels": [
        { "id": "CNN.US", "display_names": ["CNN"] },
        { "id": "cnn.us", "display_names": ["CNN"] }
      ],
      "expect": "CNN.US"
    }
  ]
}
