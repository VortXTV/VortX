    { "name": "minus_0300_to_utc", "s": "20260629110000 -0300", "ms": 1782741600000 },
    { "name": "bare_is_utc", "s": "20260629140000", "ms": 1782741600000 },
    { "name": "no_seconds_defaults_zero", "s": "202606291400 +0000", "ms": 1782741600000 },
