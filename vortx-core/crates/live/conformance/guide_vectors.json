{
  "description": "Cross-language conformance for the EPG now/next + windowed grid query views (LT4). Times are UTC milliseconds (the LT2 Program unit). EpgWindow here is the millisecond twin of the source crate's seconds-based EpgWindow: both are half-open [start, end) with identical contains/overlaps truth. now/next: now = the programme whose half-open [start, stop) contains the instant (most recently started on an overlap); a programme ending exactly at the instant is NOT now, one starting exactly at it IS; next = the earliest programme starting at/after the instant, excluding now. grid: per requested channel (in order, empty rows kept), programmes overlapping the window, each clamped to [window.start, window.end] for display. A port must reproduce every answer byte-for-byte.",
  "now_next": [
    {
      "name": "now_is_airing_next_is_upcoming",
      "programs": [
        { "channel_id": "c", "start_utc_ms": 0, "stop_utc_ms": 100, "title": "A" },
        { "channel_id": "c", "start_utc_ms": 100, "stop_utc_ms": 200, "title": "B" },
        { "channel_id": "c", "start_utc_ms": 200, "stop_utc_ms": 300, "title": "C" }
      ],
      "channel_id": "c",
      "now_utc_ms": 150,
      "expect": {
        "now": { "channel_id": "c", "start_utc_ms": 100, "stop_utc_ms": 200, "title": "B" },
        "next": { "channel_id": "c", "start_utc_ms": 200, "stop_utc_ms": 300, "title": "C" }
      }
    },
    {
      "name": "boundary_instant_belongs_to_the_starting_programme",
      "programs": [
        { "channel_id": "c", "start_utc_ms": 0, "stop_utc_ms": 100, "title": "A" },
        { "channel_id": "c", "start_utc_ms": 100, "stop_utc_ms": 200, "title": "B" }
      ],
      "channel_id": "c",
      "now_utc_ms": 100,
      "expect": {
        "now": { "channel_id": "c", "start_utc_ms": 100, "stop_utc_ms": 200, "title": "B" }
      }
    },
    {
      "name": "gap_has_no_now_but_a_next",
      "programs": [
        { "channel_id": "c", "start_utc_ms": 0, "stop_utc_ms": 100, "title": "A" },
        { "channel_id": "c", "start_utc_ms": 200, "stop_utc_ms": 300, "title": "C" }
      ],
      "channel_id": "c",
      "now_utc_ms": 150,
      "expect": {
        "next": { "channel_id": "c", "start_utc_ms": 200, "stop_utc_ms": 300, "title": "C" }
      }
    },
    {
      "name": "zero_length_programme_is_never_now_but_can_be_next",
      "programs": [
        { "channel_id": "c", "start_utc_ms": 100, "stop_utc_ms": 100, "title": "Z" }
      ],
      "channel_id": "c",
      "now_utc_ms": 100,
      "expect": {
        "next": { "channel_id": "c", "start_utc_ms": 100, "stop_utc_ms": 100, "title": "Z" }
      }
    },
    {
      "name": "other_channel_programmes_are_ignored",
      "programs": [
        { "channel_id": "x", "start_utc_ms": 100, "stop_utc_ms": 200, "title": "OtherNow" },
        { "channel_id": "c", "start_utc_ms": 100, "stop_utc_ms": 200, "title": "Mine" }
      ],
      "channel_id": "c",
      "now_utc_ms": 150,
      "expect": {
        "now": { "channel_id": "c", "start_utc_ms": 100, "stop_utc_ms": 200, "title": "Mine" }
      }
    }
  ],
  "grid": [
    {
      "name": "clamp_both_edges_and_exclude_outside",
      "programs": [
        { "channel_id": "c", "start_utc_ms": 0, "stop_utc_ms": 150, "title": "left" },
        { "channel_id": "c", "start_utc_ms": 150, "stop_utc_ms": 250, "title": "inside" },
        { "channel_id": "c", "start_utc_ms": 250, "stop_utc_ms": 400, "title": "right" },
        { "channel_id": "c", "start_utc_ms": 400, "stop_utc_ms": 500, "title": "after" }
      ],
      "channel_ids": ["c"],
      "window": { "start_utc_ms": 100, "end_utc_ms": 300 },
      "expect": [
        {
          "channel_id": "c",
          "programs": [
            { "program": { "channel_id": "c", "start_utc_ms": 0, "stop_utc_ms": 150, "title": "left" }, "clamped_start_ms": 100, "clamped_stop_ms": 150 },
            { "program": { "channel_id": "c", "start_utc_ms": 150, "stop_utc_ms": 250, "title": "inside" }, "clamped_start_ms": 150, "clamped_stop_ms": 250 },
            { "program": { "channel_id": "c", "start_utc_ms": 250, "stop_utc_ms": 400, "title": "right" }, "clamped_start_ms": 250, "clamped_stop_ms": 300 }
          ]
        }
      ]
    },
    {
      "name": "empty_row_kept_and_channel_order_preserved",
      "programs": [
        { "channel_id": "a", "start_utc_ms": 0, "stop_utc_ms": 100, "title": "A" }
      ],
      "channel_ids": ["b", "a"],
      "window": { "start_utc_ms": 0, "end_utc_ms": 100 },
      "expect": [
        { "channel_id": "b", "programs": [] },
        {
          "channel_id": "a",
          "programs": [
            { "program": { "channel_id": "a", "start_utc_ms": 0, "stop_utc_ms": 100, "title": "A" }, "clamped_start_ms": 0, "clamped_stop_ms": 100 }
          ]
        }
      ]
    },
    {
      "name": "ms_unit_pin_window_is_milliseconds_not_seconds",
      "programs": [
        { "channel_id": "c", "start_utc_ms": 1500, "stop_utc_ms": 2500, "title": "P" }
      ],
      "channel_ids": ["c"],
      "window": { "start_utc_ms": 1000, "end_utc_ms": 2000 },
      "expect": [
        {
          "channel_id": "c",
          "programs": [
            { "program": { "channel_id": "c", "start_utc_ms": 1500, "stop_utc_ms": 2500, "title": "P" }, "clamped_start_ms": 1500, "clamped_stop_ms": 2000 }
          ]
        }
      ]
    }
  ]
}
