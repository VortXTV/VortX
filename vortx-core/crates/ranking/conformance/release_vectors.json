{
  "description": "Cross-language conformance for the full release-name parser. Every implementation must lift the same structured fields from these raw release names. Pure string->struct, exactly reproducible.",
  "cases": [
    {
      "name": "uhd_remux_movie",
      "input": "The.Movie.2024.2160p.UHD.BluRay.REMUX.DV.TrueHD.Atmos.7.1.HEVC-FraMeSToR",
      "expect": {
        "title": "The Movie", "year": 2024,
        "resolution": "2160p", "source_class": "remux", "hdr": "dolby_vision", "audio": "atmos",
        "codec": "x265", "channels": "7.1", "group": "FraMeSToR"
      }
    },
    {
      "name": "series_web_dl",
      "input": "Show.S03E09.1080p.WEB-DL.DDP5.1.H.264-NTb",
      "expect": {
        "title": "Show", "season": 3, "episode": 9,
        "resolution": "1080p", "source_class": "web_dl", "hdr": "none", "audio": "dd_plus",
        "codec": "h264", "channels": "5.1", "group": "NTb"
      }
    },
    {
      "name": "hdcam_movie",
      "input": "Movie.2024.HDCAM.720p.x264-GROUP",
      "expect": {
        "title": "Movie", "year": 2024,
        "resolution": "720p", "source_class": "cam", "hdr": "none", "audio": "none",
        "codec": "h264", "group": "GROUP"
      }
    },
    {
      "name": "proper_extended_bluray",
      "input": "Film.2019.PROPER.EXTENDED.1080p.BluRay.DTS-HD.x265-DON",
      "expect": {
        "title": "Film", "year": 2019,
        "resolution": "1080p", "source_class": "blu_ray", "hdr": "none", "audio": "dts_hd_ma",
        "codec": "x265", "edition": "Extended", "group": "DON", "proper": true
      }
    },
    {
      "name": "anime_multi_repack",
      "input": "Anime.S01E13.REPACK.1080p.Multi.x265-Grp",
      "expect": {
        "title": "Anime", "season": 1, "episode": 13,
        "resolution": "1080p", "source_class": "unknown", "hdr": "none", "audio": "none",
        "codec": "x265", "languages": ["multi"], "group": "Grp", "repack": true
      }
    },
    {
      "name": "group_ignores_extension",
      "input": "Movie.2020.1080p.BluRay.x264-GRP.mkv",
      "expect": {
        "title": "Movie", "year": 2020,
        "resolution": "1080p", "source_class": "blu_ray", "hdr": "none", "audio": "none",
        "codec": "h264", "group": "GRP"
      }
    }
  ]
}
