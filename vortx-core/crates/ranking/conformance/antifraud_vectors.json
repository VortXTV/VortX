{
  "description": "Cross-language conformance for anti-fraud stream validation. Each case pins the verdict (keep, or drop with a reason) for a candidate stream. Fixed-order checks, exactly reproducible.",
  "cases": [
    {
      "name": "normal_1080p_movie_kept",
      "input": { "name": "Movie 2024 1080p BluRay x264-GRP", "files": ["movie.2024.1080p.mkv"], "size_bytes": 3000000000, "runtime_minutes": 120 },
      "expect": { "verdict": "keep" }
    },
    {
      "name": "executable_dropped",
      "input": { "name": "Movie 2024 1080p", "files": ["setup.exe", "readme.txt"] },
      "expect": { "verdict": "drop", "reason": "non_video_file" }
    },
    {
      "name": "sample_only_dropped",
      "input": { "name": "Movie 2024 1080p", "files": ["movie-sample.mkv"] },
      "expect": { "verdict": "drop", "reason": "sample_file" }
    },
    {
      "name": "password_trap_dropped",
      "input": { "name": "Movie", "files": ["password.txt", "movie.mkv"] },
      "expect": { "verdict": "drop", "reason": "trap" }
    },
    {
      "name": "ninety_gb_22_minute_episode_dropped",
      "input": { "name": "Show S01E01 1080p", "files": ["ep.mkv"], "size_bytes": 90000000000, "runtime_minutes": 22 },
      "expect": { "verdict": "drop", "reason": "size_per_minute_too_high" }
    },
    {
      "name": "tiny_fake_dropped",
      "input": { "name": "Movie 2024 1080p", "files": ["movie.mkv"], "size_bytes": 30000000, "runtime_minutes": 120 },
      "expect": { "verdict": "drop", "reason": "size_per_minute_too_low" }
    },
    {
      "name": "fake_4k_dropped",
      "input": { "name": "Movie 2024 2160p", "files": ["movie.mkv"], "size_bytes": 300000000, "runtime_minutes": 120 },
      "expect": { "verdict": "drop", "reason": "mislabeled_resolution" }
    },
    {
      "name": "real_4k_remux_kept",
      "input": { "name": "Movie 2024 2160p BluRay REMUX", "files": ["movie.mkv"], "size_bytes": 60000000000, "runtime_minutes": 120 },
      "expect": { "verdict": "keep" }
    }
  ]
}
