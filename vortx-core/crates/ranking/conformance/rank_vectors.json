{
  "description": "Cross-language conformance for the FIXED-POINT ranker. Because the score is now an i64 in milli-points (human weight x 1000 + an integer size term) with no float on the scoring path, both the exact score AND the resulting order can be pinned byte-for-byte on every platform. Each case ranks `streams` (label + optional video_size bytes + cached flag) under `prefs` and pins the full output as ordered (raw_index, score) pairs. Scores are derived from the weight contract: tier 2160=60000/1080=45000/720=30000/480=15000; preferred-source bonus = rank*100000; cached(+8000) when cached_first; source remux230/bluray150/webdl90/web75/hdtv40/cam5; hdr dv120/hdr10+80/hdr1060; audio atmos90/truehd70/dtshdma60/ddplus30; repack+5; size = clamp(bytes*150/GiB, 0, 12000) milli; all human weights x1000.",
  "cases": [
    {
      "name": "cached_4k_beats_uncached_then_resolution_ladder",
      "prefs": {},
      "streams": [
        { "label": "2160p WEB-DL", "cached": true },
        { "label": "1080p WEB-DL", "cached": false },
        { "label": "720p HDTV x264", "cached": false }
      ],
      "expect": [
        { "raw_index": 0, "score": 68090000 },
        { "raw_index": 1, "score": 45090000 },
        { "raw_index": 2, "score": 30040000 }
      ]
    },
    {
      "name": "source_preference_is_the_top_key",
      "prefs": { "source_type_order": ["remux"] },
      "streams": [
        { "label": "1080p BluRay REMUX", "cached": false },
        { "label": "2160p WEBRip", "cached": false }
      ],
      "expect": [
        { "raw_index": 0, "score": 145230000 },
        { "raw_index": 1, "score": 60075000 }
      ]
    },
    {
      "name": "size_is_a_small_integer_tiebreaker",
      "prefs": {},
      "streams": [
        { "label": "1080p WEB-DL", "cached": false },
        { "label": "1080p WEB-DL", "cached": false, "video_size": 10737418240 }
      ],
      "expect": [
        { "raw_index": 1, "score": 45091500 },
        { "raw_index": 0, "score": 45090000 }
      ]
    },
    {
      "name": "dolby_vision_atmos_remux_4k_cached",
      "prefs": {},
      "streams": [
        { "label": "2160p BluRay REMUX Dolby Vision Atmos", "cached": true }
      ],
      "expect": [
        { "raw_index": 0, "score": 68440000 }
      ]
    },
    {
      "name": "typed_vortx_score_inputs_beat_the_title",
      "prefs": {},
      "streams": [
        { "label": "Movie 2024 480p HDCAM", "vortx": { "resolution": "2160p", "tags": ["remux", "dv", "atmos"] } },
        { "label": "Movie 2024 1080p WEB-DL" }
      ],
      "expect": [
        { "raw_index": 0, "score": 60440000 },
        { "raw_index": 1, "score": 45090000 }
      ]
    },
    {
      "name": "seeders_break_a_within_tier_tie_with_diminishing_returns",
      "prefs": {},
      "streams": [
        { "label": "1080p WEB-DL", "vortx": { "resolution": "1080p", "tags": ["web-dl"], "seeders": 1024 } },
        { "label": "1080p WEB-DL", "vortx": { "resolution": "1080p", "tags": ["web-dl"], "seeders": 4 } }
      ],
      "expect": [
        { "raw_index": 0, "score": 45110000 },
        { "raw_index": 1, "score": 45096000 }
      ]
    },
    {
      "name": "distinct_sources_confidence_saturates_at_quorum",
      "prefs": {},
      "streams": [
        { "label": "1080p WEB-DL", "vortx": { "resolution": "1080p", "tags": ["web-dl"], "sources": 5 } },
        { "label": "1080p WEB-DL", "vortx": { "resolution": "1080p", "tags": ["web-dl"], "sources": 1 } }
      ],
      "expect": [
        { "raw_index": 0, "score": 45096000 },
        { "raw_index": 1, "score": 45092000 }
      ]
    },
    {
      "name": "seeders_never_jump_the_resolution_tier",
      "prefs": {},
      "streams": [
        { "label": "720p", "vortx": { "resolution": "720p", "seeders": 99999 } },
        { "label": "1080p", "vortx": { "resolution": "1080p" } }
      ],
      "expect": [
        { "raw_index": 1, "score": 45000000 },
        { "raw_index": 0, "score": 30020000 }
      ]
    }
  ]
}
