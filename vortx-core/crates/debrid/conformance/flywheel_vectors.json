{
  "description": "Cross-language conformance for the per-token debrid rate budget. Each case replays an ordered list of calls (kind = cached | uncached, with the wall-clock `now` in seconds) through one fixed-window RateMeter and pins the allow/deny decision per call. Fixed-window: a cached call resets the minute counter when 60s have elapsed since the window start; an uncached call resets the hour counter at 3600s. Integer-only, so every platform must agree byte-for-byte.",
  "cases": [
    {
      "name": "cached_caps_at_budget_then_new_minute_resets",
      "cached_per_min": 3,
      "uncached_per_hour": 100,
      "calls": [
        { "kind": "cached", "now": 0 },
        { "kind": "cached", "now": 10 },
        { "kind": "cached", "now": 30 },
        { "kind": "cached", "now": 59 },
        { "kind": "cached", "now": 60 },
        { "kind": "cached", "now": 61 }
      ],
      "expect_allowed": [true, true, true, false, true, true]
    },
    {
      "name": "uncached_caps_per_hour_then_resets",
      "cached_per_min": 100,
      "uncached_per_hour": 2,
      "calls": [
        { "kind": "uncached", "now": 0 },
        { "kind": "uncached", "now": 1000 },
        { "kind": "uncached", "now": 3599 },
        { "kind": "uncached", "now": 3600 }
      ],
      "expect_allowed": [true, true, false, true]
    },
    {
      "name": "cached_and_uncached_budgets_are_independent",
      "cached_per_min": 1,
      "uncached_per_hour": 1,
      "calls": [
        { "kind": "cached", "now": 0 },
        { "kind": "uncached", "now": 0 },
        { "kind": "cached", "now": 0 },
        { "kind": "uncached", "now": 0 }
      ],
      "expect_allowed": [true, true, false, false]
    },
    {
      "name": "zero_budget_denies_everything",
      "cached_per_min": 0,
      "uncached_per_hour": 0,
      "calls": [
        { "kind": "cached", "now": 0 },
        { "kind": "uncached", "now": 0 },
        { "kind": "cached", "now": 9999 }
      ],
      "expect_allowed": [false, false, false]
    }
  ]
}
