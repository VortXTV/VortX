{
  "description": "Cross-language conformance for meta-addressed progress / Continue-Watching. Each case applies a sequence of progress actions to the owner profile and pins the resulting Continue Watching ids (newest first), watched map, and resume keys. The engine owns the CW rules (finished at 900 permille, cap 30, newest first), so every platform derives the identical rail.",
  "cases": [
    {
      "name": "in_progress_then_finish",
      "actions": [
        { "type": "report_progress", "metaId": "a", "name": "A", "positionMs": 60000, "durationMs": 600000 },
        { "type": "report_progress", "metaId": "b", "name": "B", "positionMs": 300000, "durationMs": 600000 },
        { "type": "report_progress", "metaId": "a", "videoId": "a", "name": "A", "positionMs": 595000, "durationMs": 600000 }
      ],
      "expect_cw": ["b"],
      "expect_watched": { "a": ["a"] },
      "expect_resume_keys": ["b"]
    },
    {
      "name": "newest_first_and_dismiss",
      "actions": [
        { "type": "report_progress", "metaId": "x", "name": "X", "positionMs": 60000, "durationMs": 600000 },
        { "type": "report_progress", "metaId": "y", "name": "Y", "positionMs": 60000, "durationMs": 600000 },
        { "type": "report_progress", "metaId": "x", "name": "X", "positionMs": 120000, "durationMs": 600000 },
        { "type": "remove_from_continue_watching", "metaId": "y" }
      ],
      "expect_cw": ["x"],
      "expect_watched": {},
      "expect_resume_keys": ["x", "y"]
    }
  ]
}
