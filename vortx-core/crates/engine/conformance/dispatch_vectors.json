{
  "description": "Cross-language conformance for the engine dispatch contract. Every platform bridge (Swift, Kotlin, web) must feed these JSON actions through dispatch_json and get back these exact JSON results + events. The action/result/event field names are the FFI seam.",
  "ownerId": "owner",
  "ownerName": "Owner",
  "now": 1000,
  "steps": [
    {
      "action": { "type": "add_profile", "id": "kid", "name": "Kid" },
      "expect": { "ok": true, "events": [{ "event": "profile_added", "id": "kid" }] }
    },
    {
      "action": { "type": "add_profile", "id": "guest", "name": "Guest" },
      "expect": { "ok": true, "events": [{ "event": "profile_added", "id": "guest" }] }
    },
    {
      "action": { "type": "switch_profile", "id": "kid" },
      "expect": { "ok": true, "events": [{ "event": "profile_switched", "id": "kid" }] }
    },
    {
      "action": { "type": "switch_profile", "id": "ghost" },
      "expect": { "ok": false, "error": "profile not found", "events": [] }
    },
    {
      "action": { "type": "delete_profile", "id": "owner" },
      "expect": { "ok": false, "error": "cannot delete the owner profile", "events": [] }
    },
    {
      "action": { "type": "delete_profile", "id": "guest" },
      "expect": { "ok": true, "events": [{ "event": "profile_deleted", "id": "guest" }] }
    },
    {
      "action": { "type": "get_state" },
      "expect": { "ok": true, "events": [] }
    }
  ]
}
