{
  "description": "Cross-language conformance for the NativeVortx first-class source: registry routing (supports) + the host fetch plan (plan URL). Given a vortx-source/1 manifest and requests, supports() gates by capability + type + content idPrefix (catalog ids are NOT id-gated), and plan() builds the byte-exact Stremio resource URL from the manifest transport, stripping the /manifest.vortx.json suffix. A native source is reached over HTTP with the same /resource/type/id.json grammar as a Stremio addon; only the manifest path and the typed behaviorHints.vortx differ. url is omitted when supports is false (plan returns None).",
  "cases": [
    {
      "name": "http_native_source_gating_and_plan_urls",
      "manifest": {
        "schema": "vortx-source/1",
        "id": "tv.vortx.native.demo",
        "version": "1.0.0",
        "name": "Demo Native",
        "kind": "native_vortx",
        "capabilities": ["catalog", "stream", "meta"],
        "types": ["movie", "series"],
        "idPrefixes": ["tt"],
        "transport": { "kind": "stremio_http", "manifest_url": "https://src.vortx.tv/manifest.vortx.json" },
        "ranking": { "emitsScoreInputs": true }
      },
      "requests": [
        { "kind": "stream", "type": "movie", "id": "tt0111161", "supports": true, "url": "https://src.vortx.tv/stream/movie/tt0111161.json" },
        { "kind": "meta", "type": "series", "id": "tt0903747", "supports": true, "url": "https://src.vortx.tv/meta/series/tt0903747.json" },
        { "kind": "catalog", "type": "movie", "id": "top", "supports": true, "url": "https://src.vortx.tv/catalog/movie/top.json" },
        { "kind": "stream", "type": "movie", "id": "kitsu:42", "supports": false },
        { "kind": "stream", "type": "music", "id": "tt0111161", "supports": false },
        { "kind": "subtitles", "type": "movie", "id": "tt0111161", "supports": false }
      ]
    },
    {
      "name": "plain_manifest_json_suffix_is_also_stripped",
      "manifest": {
        "schema": "vortx-source/1",
        "id": "tv.vortx.native.plain",
        "version": "1.0.0",
        "name": "Plain Suffix",
        "kind": "native_vortx",
        "capabilities": ["stream"],
        "types": [],
        "idPrefixes": [],
        "transport": { "kind": "stremio_http", "manifest_url": "https://p.vortx.tv/manifest.json" }
      },
      "requests": [
        { "kind": "stream", "type": "movie", "id": "tt1", "supports": true, "url": "https://p.vortx.tv/stream/movie/tt1.json" }
      ]
    }
  ]
}
