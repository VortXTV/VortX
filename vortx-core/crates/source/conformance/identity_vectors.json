{
  "description": "Cross-language conformance for cross-namespace id reconciliation. Each case feeds raw id sets (one per addon) and pins the reconciled canonical identities. Connected-components over shared ids, exactly reproducible.",
  "cases": [
    {
      "name": "five_variants_collapse_to_one",
      "sets": [
        ["tt0111161", "tmdb:278"],
        ["tmdb:278", "tvdb:111"],
        ["tvdb:111"],
        ["tt0111161", "trakt:1"],
        ["imdb:tt0111161"]
      ],
      "expect": [
        { "ids": { "imdb": "tt0111161", "tmdb": "278", "trakt": "1", "tvdb": "111" }, "support": 5, "conflicted": false }
      ]
    },
    {
      "name": "two_distinct_titles",
      "sets": [["tt1"], ["tt2"]],
      "expect": [
        { "ids": { "imdb": "tt1" }, "support": 1, "conflicted": false },
        { "ids": { "imdb": "tt2" }, "support": 1, "conflicted": false }
      ]
    },
    {
      "name": "shared_id_conflict_is_flagged",
      "sets": [["tt1", "tmdb:5"], ["tt1", "tmdb:9"]],
      "expect": [
        { "ids": { "imdb": "tt1", "tmdb": "5" }, "support": 2, "conflicted": true }
      ]
    },
    {
      "name": "anime_namespaces",
      "sets": [
        ["anilist:21", "mal:21"],
        ["mal:21", "kitsu:1"]
      ],
      "expect": [
        { "ids": { "anilist": "21", "kitsu": "1", "mal": "21" }, "support": 2, "conflicted": false }
      ]
    }
  ]
}
