{
  "description": "Cross-language conformance for subtitle auto-selection. Every implementation must pick the same track index (or none) for the same tracks + prefs. Pure ranked-preference logic, exactly reproducible.",
  "cases": [
    {
      "name": "preferred_language_beats_higher_tier_other_language",
      "tracks": [
        { "id": "es", "lang": "es", "format": "srt", "tier": "embedded" },
        { "id": "en", "lang": "en", "format": "srt", "tier": "open_subtitles" }
      ],
      "prefs": { "languages": ["en"] },
      "expectIndex": 1
    },
    {
      "name": "language_priority_order",
      "tracks": [
        { "id": "es", "lang": "es", "format": "srt", "tier": "embedded" },
        { "id": "en", "lang": "en", "format": "srt", "tier": "embedded" }
      ],
      "prefs": { "languages": ["es", "en"] },
      "expectIndex": 0
    },
    {
      "name": "region_subtag_matches",
      "tracks": [
        { "id": "ptbr", "lang": "pt-BR", "format": "srt", "tier": "community" }
      ],
      "prefs": { "languages": ["pt"] },
      "expectIndex": 0
    },
    {
      "name": "no_match_in_required_language",
      "tracks": [
        { "id": "fr", "lang": "fr", "format": "srt", "tier": "embedded" }
      ],
      "prefs": { "languages": ["en"] },
      "expectIndex": null
    },
    {
      "name": "want_forced_picks_forced",
      "tracks": [
        { "id": "plain", "lang": "en", "format": "srt", "tier": "embedded" },
        { "id": "forced", "lang": "en", "forced": true, "format": "srt", "tier": "embedded" }
      ],
      "prefs": { "languages": ["en"], "wantForced": true },
      "expectIndex": 1
    },
    {
      "name": "default_avoids_forced",
      "tracks": [
        { "id": "forced", "lang": "en", "forced": true, "format": "srt", "tier": "embedded" },
        { "id": "plain", "lang": "en", "format": "srt", "tier": "embedded" }
      ],
      "prefs": { "languages": ["en"] },
      "expectIndex": 1
    },
    {
      "name": "format_priority_breaks_ties",
      "tracks": [
        { "id": "srt", "lang": "en", "format": "srt", "tier": "embedded" },
        { "id": "vtt", "lang": "en", "format": "vtt", "tier": "embedded" }
      ],
      "prefs": { "languages": ["en"], "formatPriority": ["vtt", "srt"] },
      "expectIndex": 1
    },
    {
      "name": "tier_breaks_ties",
      "tracks": [
        { "id": "gen", "lang": "en", "format": "srt", "tier": "generated" },
        { "id": "emb", "lang": "en", "format": "srt", "tier": "embedded" }
      ],
      "prefs": { "languages": ["en"] },
      "expectIndex": 1
    },
    {
      "name": "rating_breaks_remaining_ties",
      "tracks": [
        { "id": "low", "lang": "en", "format": "srt", "tier": "open_subtitles", "rating": 100 },
        { "id": "high", "lang": "en", "format": "srt", "tier": "open_subtitles", "rating": 950 }
      ],
      "prefs": { "languages": ["en"] },
      "expectIndex": 1
    },
    {
      "name": "no_language_pref_picks_most_trusted",
      "tracks": [
        { "id": "gen", "lang": "de", "format": "srt", "tier": "generated" },
        { "id": "emb", "lang": "ja", "format": "srt", "tier": "embedded" }
      ],
      "prefs": {},
      "expectIndex": 1
    }
  ]
}
