{
  "description": "Cross-language conformance for the field-level watch-state CRDT. Each case merges two states and pins the result plus the derived is_watched / is_removed. Shows the domain-correct semantics: a stale pause never un-finishes, a reset un-finishes, removal is revived by later activity, times_watched takes the max. Merge is commutative, so the test also checks merge(b,a).",
  "cases": [
    {
      "name": "stale_pause_never_unfinishes",
      "a": { "resume_ms": 300000, "resume_at": 100 },
      "b": { "watched_at": 200, "times_watched": 1 },
      "expect": { "resume_ms": 300000, "resume_at": 100, "watched_at": 200, "times_watched": 1 },
      "is_watched": true,
      "is_removed": false
    },
    {
      "name": "reset_unfinishes",
      "a": { "watched_at": 100, "times_watched": 1 },
      "b": { "reset_at": 200 },
      "expect": { "watched_at": 100, "times_watched": 1, "reset_at": 200 },
      "is_watched": false,
      "is_removed": false
    },
    {
      "name": "refinish_after_reset",
      "a": { "watched_at": 100, "times_watched": 1, "reset_at": 200 },
      "b": { "watched_at": 300, "times_watched": 2 },
      "expect": { "watched_at": 300, "times_watched": 2, "reset_at": 200 },
      "is_watched": true,
      "is_removed": false
    },
    {
      "name": "removal_revived_by_later_activity",
      "a": { "removed_at": 100 },
      "b": { "resume_ms": 60000, "resume_at": 200 },
      "expect": { "resume_ms": 60000, "resume_at": 200, "removed_at": 100 },
      "is_watched": false,
      "is_removed": false
    },
    {
      "name": "removal_stays_when_activity_is_older",
      "a": { "resume_ms": 5000, "resume_at": 50 },
      "b": { "removed_at": 200 },
      "expect": { "resume_ms": 5000, "resume_at": 50, "removed_at": 200 },
      "is_watched": false,
      "is_removed": true
    },
    {
      "name": "times_watched_takes_max",
      "a": { "times_watched": 3 },
      "b": { "times_watched": 1 },
      "expect": { "times_watched": 3 },
      "is_watched": false,
      "is_removed": false
    },
    {
      "name": "resume_never_rewinds_on_tie",
      "a": { "resume_ms": 500000, "resume_at": 100 },
      "b": { "resume_ms": 100000, "resume_at": 100 },
      "expect": { "resume_ms": 500000, "resume_at": 100 },
      "is_watched": false,
      "is_removed": false
    }
  ]
}
