{
  "description": "Cross-language conformance for the external-tracker scrobble decision. Given a playback event + position/duration + config, scrobble() returns the action the host sends to Trakt/Simkl/MAL. The 'watched' flag on a stop is progress >= watched_at_permille, pinned here so a title flips watched identically on every platform. Integer-only.",
  "cases": [
    { "name": "stop_90pct_is_watched", "event": "stop", "position_ms": 540000, "duration_ms": 600000, "watched_at_permille": 800, "expect": { "action": "stop", "progress_permille": 900, "watched": true } },
    { "name": "stop_50pct_not_watched", "event": "stop", "position_ms": 300000, "duration_ms": 600000, "watched_at_permille": 800, "expect": { "action": "stop", "progress_permille": 500, "watched": false } },
    { "name": "stop_exactly_at_threshold_is_watched", "event": "stop", "position_ms": 480000, "duration_ms": 600000, "watched_at_permille": 800, "expect": { "action": "stop", "progress_permille": 800, "watched": true } },
    { "name": "start_carries_progress", "event": "start", "position_ms": 0, "duration_ms": 600000, "watched_at_permille": 800, "expect": { "action": "start", "progress_permille": 0 } },
    { "name": "pause_carries_progress", "event": "pause", "position_ms": 540000, "duration_ms": 600000, "watched_at_permille": 800, "expect": { "action": "pause", "progress_permille": 900 } },
    { "name": "zero_duration_is_none", "event": "stop", "position_ms": 100, "duration_ms": 0, "watched_at_permille": 800, "expect": { "action": "none" } }
  ]
}
