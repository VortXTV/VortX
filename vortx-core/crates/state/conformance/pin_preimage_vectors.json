[
  {
    "description": "basic id and 4-digit pin",
    "profile_id": "abc",
    "pin": "0420",
    "expected_preimage": "abc:0420"
  },
  {
    "description": "uuid-style owner id",
    "profile_id": "owner-uuid-1",
    "pin": "1234",
    "expected_preimage": "owner-uuid-1:1234"
  },
