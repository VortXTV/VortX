{
  "description": "Cross-language conformance for the streaming torrent piece-selection policy. `have[i]` is true when piece i is downloaded. Each case pins the ordered (piece, priority) requests: header first, then footer (last footer_pieces), then the critical window at the playhead, then read-ahead, then the sequential tail, each missing piece once at its highest-priority slot. Integer-only and deterministic.",
  "cases": [
    {
      "name": "fresh_start_all_missing",
      "have": [false, false, false, false, false, false, false, false],
      "playhead": 0,
      "critical_window": 2,
      "readahead_window": 2,
      "footer_pieces": 1,
      "order": [
        { "piece": 0, "priority": "critical" },
        { "piece": 7, "priority": "critical" },
        { "piece": 1, "priority": "critical" },
        { "piece": 2, "priority": "high" },
        { "piece": 3, "priority": "high" },
        { "piece": 4, "priority": "normal" },
        { "piece": 5, "priority": "normal" },
        { "piece": 6, "priority": "normal" }
      ]
    },
    {
      "name": "skips_already_downloaded_header_and_footer",
      "have": [true, false, false, false, false, true],
      "playhead": 0,
      "critical_window": 2,
      "readahead_window": 1,
      "footer_pieces": 1,
      "order": [
        { "piece": 1, "priority": "critical" },
        { "piece": 2, "priority": "high" },
        { "piece": 3, "priority": "normal" },
        { "piece": 4, "priority": "normal" }
      ]
    }
  ]
}
