{
  "description": "Cross-language conformance for the AU1 audio metadata model. A plain AudioTrack serializes byte-identically to its minimal {id,title} form (every other field is skip_serializing_if-default, so introducing this model regresses no existing wire vector). Wire keys are camelCase (trackNo/discNo/durationMs/trackIds) matching the rest of the protocol; chapters reuse the SH5 Chapter (startMs/endMs). AudioCodec is snake_case, from_wire is alias-tolerant, and is_lossless flags FLAC/ALAC/WAV/AIFF/DSD. The multi-disc order key is (disc default 1, track default last, title). A port must reproduce all of this byte-for-byte.",
  "tracks": [
    { "name": "minimal_is_just_id_and_title", "json": { "id": "t1", "title": "Song" } },
    {
      "name": "full_track_with_chapters_and_codec",
      "json": {
        "id": "ab1",
        "title": "Chapter 1",
        "artist": "Author",
        "album": "The Book",
        "trackNo": 1,
        "discNo": 1,
        "durationMs": 3600000,
        "codec": "flac",
        "chapters": [ { "startMs": 0, "endMs": 60000, "title": "Intro" } ]
      }
    },
    {
      "name": "unknown_codec_omits_the_key",
      "json": { "id": "t2", "title": "Lossy", "durationMs": 180000 }
    }
  ],
  "codecs": [
    { "wire": "flac", "expect": "flac", "lossless": true },
    { "wire": "FLAC", "expect": "flac", "lossless": true },
    { "wire": "apple lossless", "expect": "alac", "lossless": true },
    { "wire": "pcm", "expect": "wav", "lossless": true },
    { "wire": "aif", "expect": "aiff", "lossless": true },
    { "wire": "dsf", "expect": "dsd", "lossless": true },
    { "wire": "m4a", "expect": "aac", "lossless": false },
    { "wire": "mp3", "expect": "mp3", "lossless": false },
    { "wire": "opus", "expect": "opus", "lossless": false },
    { "wire": "vorbis", "expect": "vorbis", "lossless": false },
    { "wire": "ogg", "expect": "ogg", "lossless": false },
    { "wire": "weirdcodec", "expect": "unknown", "lossless": false }
  ],
  "ordering": [
    {
      "name": "multi_disc_disc_then_track_then_title_then_loose_trails",
      "tracks": [
        { "id": "d2t1", "title": "B", "discNo": 2, "trackNo": 1 },
        { "id": "d1t2", "title": "A", "discNo": 1, "trackNo": 2 },
        { "id": "d1t1", "title": "Z", "discNo": 1, "trackNo": 1 },
        { "id": "loose", "title": "loose", "discNo": 1 }
      ],
      "expect_order": ["d1t1", "d1t2", "loose", "d2t1"]
    },
    {
      "name": "missing_disc_is_disc_one",
      "tracks": [
        { "id": "no_disc", "title": "x", "trackNo": 1 },
        { "id": "disc2", "title": "y", "discNo": 2, "trackNo": 1 }
      ],
      "expect_order": ["no_disc", "disc2"]
    }
  ]
}
