{
  "description": "Cross-language conformance for the typed behaviorHints.vortx side-channel (VortxStreamHints). This is the byte-frozen contract the Singularity Worker emits and the engine consumes: the engine reads these typed fields instead of regex-parsing the release title, so a stream ranks identically on every platform. Each case pins one emitted JSON object to the typed fields it must deserialize into. Field renames: cachedServices/sizeBytes/fileIdx/nzbHash are camelCase on the wire. Every field is optional so a partial object (http has no seeders, nzb has no infohash) and an absent object (plain Stremio) both degrade to the title-parse fallback. The object rides inside Stream.behaviorHints.vortx; these cases isolate the inner object.",
  "cases": [
    {
      "name": "full_torrent_object_all_fields",
      "json": {
        "kind": "torrent",
        "cachedServices": ["realdebrid", "torbox"],
        "seeders": 412,
        "sizeBytes": 23804378112,
        "resolution": "2160p",
        "languages": ["en", "ja"],
        "tags": ["remux", "dv", "atmos"],
        "sources": 5,
        "pack": true,
        "fileIdx": 3,
        "nzbHash": null
      },
      "expect": {
        "kind": "torrent",
        "cached_services": ["realdebrid", "torbox"],
        "seeders": 412,
        "size_bytes": 23804378112,
        "resolution": "2160p",
        "languages": ["en", "ja"],
        "tags": ["remux", "dv", "atmos"],
        "sources": 5,
        "pack": true,
        "file_idx": 3,
        "nzb_hash": null
      }
    },
    {
      "name": "http_object_no_seeders_no_pack",
      "json": {
        "kind": "http",
        "cachedServices": [],
        "resolution": "1080p",
        "tags": ["web-dl"],
        "sources": 3
      },
      "expect": {
        "kind": "http",
        "cached_services": [],
        "seeders": null,
        "size_bytes": null,
        "resolution": "1080p",
        "languages": [],
        "tags": ["web-dl"],
        "sources": 3,
        "pack": null,
        "file_idx": null,
        "nzb_hash": null
      }
    },
    {
      "name": "nzb_object_carries_nzbhash_no_infohash_fields",
      "json": {
        "kind": "nzb",
        "sizeBytes": 5368709120,
        "resolution": "1080p",
        "nzbHash": "d41d8cd98f00b204e9800998ecf8427e"
      },
      "expect": {
        "kind": "nzb",
        "cached_services": [],
        "seeders": null,
        "size_bytes": 5368709120,
        "resolution": "1080p",
        "languages": [],
        "tags": [],
        "sources": null,
        "pack": null,
        "file_idx": null,
        "nzb_hash": "d41d8cd98f00b204e9800998ecf8427e"
      }
    },
    {
      "name": "empty_object_is_all_defaults",
      "json": {},
      "expect": {
        "kind": null,
        "cached_services": [],
        "seeders": null,
        "size_bytes": null,
        "resolution": null,
        "languages": [],
        "tags": [],
        "sources": null,
        "pack": null,
        "file_idx": null,
        "nzb_hash": null
      }
    }
  ]
}
