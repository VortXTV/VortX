    "Source failed, trying another…  (%@/%@)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Source failed, trying another…  (%1$@/%2$@)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sorgente non riuscita, ne provo un'altra…  (%@/%@)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuente fallida, probando otra…  (%@/%@)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la source, tentative d'une autre…  (%@/%@)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelle fehlgeschlagen, eine andere wird versucht …  (%@/%@)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A fonte falhou, tentando outra…  (%@/%@)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ソースが失敗しました。別のものを試しています…  (%@/%@)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "소스 실패, 다른 소스 시도 중…  (%@/%@)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "来源失败，正在尝试另一个…  (%@/%@)"
          }
        }
      }
    },
    "Source type priority": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Priorità tipo di sorgente"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prioridad de tipo de fuente"
          }
        },
        "fr": {
          "stringUnit": {
