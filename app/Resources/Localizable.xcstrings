    "%@ · tap to get it": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · tocca per ottenerlo"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · toca para obtenerlo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · touchez pour l'obtenir"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · zum Abrufen tippen"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · toque para obter"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · タップして取得"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · 탭하여 가져오기"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · 点按获取"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · нажмите, чтобы получить"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · पाने के लिए टैप करें"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · انقر للحصول عليه"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · almak için dokunun"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · toque para obter"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · tik om het op te halen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · dotknij, aby pobrać"
          }
        },
        "sv": {
          "stringUnit": {
