    "Audio & Subtitles": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio e sottotitoli"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio y subtítulos"
          }
        }
