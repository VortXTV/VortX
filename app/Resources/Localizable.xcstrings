        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Style des sous-titres"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Untertitel-Stil"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estilo das legendas"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "字幕スタイル"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자막 스타일"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "字幕样式"
          }
        }
      }
    },
    "Switch to %@ to use it and edit its settings.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passa a %@ per usarlo e modificarne le impostazioni."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia a %@ para usarlo y editar sus ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Basculez vers %@ pour l'utiliser et modifier ses réglages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechsle zu %@, um es zu verwenden und seine Einstellungen zu bearbeiten."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mude para %@ para usá-lo e editar suas configurações."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ に切り替えて使用し、その設定を編集します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@(으)로 전환하여 사용하고 설정을 편집하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换到 %@ 以使用它并编辑其设置。"
          }
        }
      }
    },
    "That link is not responding right now. Try a different source.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo link non risponde al momento. Prova una sorgente diversa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ese enlace no responde en este momento. Prueba una fuente diferente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce lien ne répond pas pour le moment. Essayez une autre source."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Link antwortet gerade nicht. Probiere eine andere Quelle."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esse link não está respondendo agora. Tente outra fonte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのリンクは現在応答していません。別のソースを試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해당 링크가 지금 응답하지 않습니다. 다른 소스를 시도해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该链接当前没有响应。请尝试其他来源。"
          }
        }
      }
    },
    "That subtitle source did not respond in time. Try another one.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa sorgente di sottotitoli non ha risposto in tempo. Provane un'altra."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa fuente de subtítulos no respondió a tiempo. Prueba con otra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette source de sous-titres n'a pas répondu à temps. Essayez-en une autre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Untertitelquelle hat nicht rechtzeitig geantwortet. Probiere eine andere."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa fonte de legendas não respondeu a tempo. Tente outra."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その字幕ソースは時間内に応答しませんでした。別のものを試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해당 자막 소스가 제때 응답하지 않았습니다. 다른 것을 시도해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该字幕来源未能及时响应。请尝试另一个。"
          }
        }
      }
    },
    "The app quits immediately. Open it again from the Home Screen; the streaming server restarts with it.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app si chiude immediatamente. Riaprila dalla schermata Home; il server di streaming si riavvia con essa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app se cierra de inmediato. Vuelve a abrirla desde la pantalla de inicio; el servidor de streaming se reinicia con ella."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app se ferme immédiatement. Rouvrez-la depuis l'écran d'accueil ; le serveur de streaming redémarre avec elle."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App wird sofort beendet. Öffne sie erneut über den Home-Bildschirm; der Streaming-Server startet mit ihr neu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O app fecha imediatamente. Abra-o novamente pela Tela de Início; o servidor de streaming reinicia junto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリはすぐに終了します。ホーム画面から再度開いてください。ストリーミングサーバーも一緒に再起動します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱이 즉시 종료됩니다. 홈 화면에서 다시 여세요. 스트리밍 서버도 함께 다시 시작됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用会立即退出。请从主屏幕再次打开它；流媒体服务器会随之重启。"
          }
        }
      }
    },
    "The main profile. It uses your Stremio account's own watch history, like before profiles existed.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il profilo principale. Usa la cronologia di visione del tuo account Stremio, come prima che esistessero i profili."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El perfil principal. Usa el propio historial de visualización de tu cuenta Stremio, como antes de que existieran los perfiles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le profil principal. Il utilise l'historique de visionnage propre à votre compte Stremio, comme avant l'existence des profils."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Hauptprofil. Es verwendet den eigenen Wiedergabeverlauf deines Stremio-Kontos, wie vor der Einführung von Profilen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O perfil principal. Ele usa o histórico de exibição da sua própria conta Stremio, como antes de os perfis existirem."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メインのプロファイルです。プロファイルが存在する前と同じように、Stremio アカウント独自の視聴履歴を使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 프로필입니다. 프로필이 존재하기 전과 마찬가지로 Stremio 계정 자체의 시청 기록을 사용합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主配置文件。它使用你的 Stremio 账户自己的观看历史，就像配置文件出现之前那样。"
          }
        }
      }
    },
    "The player auto-picks these when a title starts. Forced shows only foreign-dialogue captions; Always shows full subtitles in your language. Foreign-language titles always get full subtitles so you can follow.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il lettore li seleziona automaticamente all'avvio di un titolo. Forzati mostra solo i sottotitoli dei dialoghi in lingua straniera; Sempre mostra i sottotitoli completi nella tua lingua. I titoli in lingua straniera ricevono sempre i sottotitoli completi così puoi seguirli."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El reproductor los selecciona automáticamente al empezar un título. Forzados muestra solo los subtítulos de diálogos en idioma extranjero; Siempre muestra los subtítulos completos en tu idioma. Los títulos en idioma extranjero siempre reciben subtítulos completos para que puedas seguirlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le lecteur les sélectionne automatiquement au démarrage d'un titre. Forcés affiche uniquement les sous-titres des dialogues en langue étrangère ; Toujours affiche les sous-titres complets dans votre langue. Les titres en langue étrangère reçoivent toujours des sous-titres complets pour que vous puissiez suivre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Player wählt diese automatisch aus, wenn ein Titel startet. „Erzwungen“ zeigt nur Untertitel für fremdsprachige Dialoge; „Immer“ zeigt vollständige Untertitel in deiner Sprache. Fremdsprachige Titel erhalten immer vollständige Untertitel, damit du folgen kannst."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O player escolhe estas automaticamente quando um título inicia. Forçadas mostra apenas as legendas de diálogos em outros idiomas; Sempre mostra legendas completas no seu idioma. Títulos em idioma estrangeiro sempre recebem legendas completas para você acompanhar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイトル開始時にプレーヤーがこれらを自動選択します。「強制」は外国語のセリフのキャプションのみを表示し、「常に」は使用言語のフル字幕を表示します。外国語のタイトルには、内容を追えるよう常にフル字幕が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "플레이어는 작품이 시작될 때 이를 자동으로 선택합니다. 강제는 외국어 대사 자막만 표시하고, 항상은 사용 언어로 전체 자막을 표시합니다. 외국어 작품은 따라갈 수 있도록 항상 전체 자막이 표시됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "播放器在影片开始时会自动选择这些。强制只显示外语对白字幕；始终会以你的语言显示完整字幕。外语影片始终会获得完整字幕，以便你跟上剧情。"
          }
        }
      }
    },
    "This account's profiles differ from this device. Merge both to keep every profile (recommended), or force one side.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I profili di questo account differiscono da quelli di questo dispositivo. Unisci entrambi per mantenere ogni profilo (consigliato), oppure forza un lato."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los perfiles de esta cuenta difieren de los de este dispositivo. Fusiona ambos para conservar todos los perfiles (recomendado), o fuerza un lado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les profils de ce compte diffèrent de ceux de cet appareil. Fusionnez les deux pour conserver tous les profils (recommandé), ou forcez un côté."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Profile dieses Kontos unterscheiden sich von diesem Gerät. Führe beide zusammen, um jedes Profil zu behalten (empfohlen), oder erzwinge eine Seite."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os perfis desta conta diferem dos deste dispositivo. Mescle os dois para manter todos os perfis (recomendado) ou force um dos lados."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアカウントのプロファイルは、このデバイスと異なります。両方をマージしてすべてのプロファイルを保持する（推奨）か、いずれか一方を強制してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 계정의 프로필이 이 기기와 다릅니다. 모든 프로필을 유지하려면 양쪽을 병합하거나(권장), 한쪽을 강제 적용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此账户的配置文件与本设备不同。合并双方以保留每个配置文件（推荐），或强制采用一方。"
          }
        }
      }
    },
    "This is shown only once. It is the only way back in if you forget your password and lose your devices. Store it somewhere safe.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Viene mostrato una sola volta. È l'unico modo per rientrare se dimentichi la password e perdi i tuoi dispositivi. Conservalo in un luogo sicuro."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto se muestra una sola vez. Es la única forma de volver a entrar si olvidas tu contraseña y pierdes tus dispositivos. Guárdalo en un lugar seguro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci n'est affiché qu'une seule fois. C'est le seul moyen de revenir si vous oubliez votre mot de passe et perdez vos appareils. Conservez-le en lieu sûr."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies wird nur einmal angezeigt. Es ist der einzige Weg zurück, falls du dein Passwort vergisst und deine Geräte verlierst. Bewahre es an einem sicheren Ort auf."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto é exibido apenas uma vez. É a única forma de voltar a entrar caso esqueça sua senha e perca seus dispositivos. Guarde-o em um lugar seguro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは一度だけ表示されます。パスワードを忘れてデバイスを失った場合に戻る唯一の方法です。安全な場所に保管してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 코드는 한 번만 표시됩니다. 비밀번호를 잊고 기기를 잃었을 때 다시 들어올 수 있는 유일한 방법입니다. 안전한 곳에 보관하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此内容仅显示一次。这是你忘记密码并丢失设备后唯一的找回方式。请将其存放在安全的地方。"
          }
        }
      }
    },
    "This magnet has %@ videos. Choose which one to play.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo magnet contiene %@ video. Scegli quale riprodurre."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este magnet tiene %@ vídeos. Elige cuál reproducir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce magnet contient %@ vidéos. Choisissez celle à lire."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Magnet enthält %@ Videos. Wähle, welches abgespielt werden soll."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este magnet tem %@ vídeos. Escolha qual reproduzir."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この magnet には %@ 本の動画があります。再生する動画を選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 magnet에는 동영상 %@개가 있습니다. 재생할 항목을 선택하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此磁力链接包含 %@ 个视频。请选择要播放的一个。"
          }
        }
      }
    },
