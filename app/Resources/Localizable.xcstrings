    "Makes every screen's text larger or smaller. Changes apply instantly.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rende il testo di ogni schermata più grande o più piccolo. Le modifiche si applicano subito."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hace el texto de cada pantalla más grande o más pequeño. Los cambios se aplican al instante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrandit ou réduit le texte de tous les écrans. Les changements s'appliquent immédiatement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Macht den Text auf jedem Bildschirm größer oder kleiner. Änderungen werden sofort übernommen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixa o texto de cada tela maior ou menor. As alterações são aplicadas instantaneamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての画面の文字を大きくまたは小さくします。変更はすぐに適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 화면의 텍스트를 더 크거나 작게 만듭니다. 변경 사항은 즉시 적용됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让每个屏幕的文字变大或变小。更改即时生效。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Делает текст на всех экранах крупнее или мельче. Изменения применяются мгновенно."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर स्क्रीन का टेक्स्ट बड़ा या छोटा करता है। बदलाव तुरंत लागू होते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يكبّر نص كل شاشة أو يصغّره. تُطبَّق التغييرات فورًا."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her ekranın metnini büyütür veya küçültür. Değişiklikler anında uygulanır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Torna o texto de todos os ecrãs maior ou menor. As alterações aplicam-se de imediato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Maakt de tekst op elk scherm groter of kleiner. Wijzigingen worden meteen toegepast."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Powiększa lub pomniejsza tekst na każdym ekranie. Zmiany są stosowane natychmiast."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Gör texten på varje skärm större eller mindre. Ändringar tillämpas direkt."
          }
        }
      }
    },
