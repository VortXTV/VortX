    "Sideload the new IPA from the GitHub releases page, your sign-in and settings carry over.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installa tramite sideload il nuovo IPA dalla pagina delle release di GitHub; il tuo accesso e le impostazioni vengono mantenuti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala mediante sideload el nuevo IPA desde la página de releases de GitHub; tu inicio de sesión y ajustes se conservan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chargez le nouveau IPA en sideload depuis la page des releases GitHub, votre connexion et vos réglages sont conservés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade die neue IPA von der GitHub-Releases-Seite per Sideload; deine Anmeldung und Einstellungen werden übernommen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça o sideload do novo IPA pela página de releases do GitHub; seu login e configurações são mantidos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub のリリースページから新しい IPA をサイドロードしてください。サインインと設定は引き継がれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub 릴리스 페이지에서 새 IPA를 사이드로드하세요. 로그인과 설정은 그대로 유지됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 GitHub 发布页旁加载新的 IPA，你的登录和设置会随之保留。"
          }
        }
      }
    },
    "Signing in pulls your add-ons and library into the app. Your account stays on this device.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accedendo, i tuoi componenti aggiuntivi e la libreria vengono caricati nell'app. Il tuo account resta su questo dispositivo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al iniciar sesión, tus complementos y tu biblioteca se cargan en la app. Tu cuenta permanece en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion importe vos add-ons et votre bibliothèque dans l'app. Votre compte reste sur cet appareil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch die Anmeldung werden deine Add-ons und deine Bibliothek in die App geladen. Dein Konto bleibt auf diesem Gerät."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fazer login traz seus complementos e biblioteca para o app. Sua conta permanece neste dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインすると、アドオンとライブラリがアプリに取り込まれます。アカウントはこのデバイスに保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인하면 부가 기능과 라이브러리가 앱으로 가져와집니다. 계정은 이 기기에 보관됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录会将你的附加组件和库拉取到应用中。你的账户保留在本设备上。"
          }
        }
      }
    },
