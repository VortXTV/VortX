          "stringUnit": {
            "state": "translated",
            "value": "%@ · tocca per ottenerlo"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · toca para obtenerlo"
          }
        }
      }
    },
    "%@ (%@)": {
      "localizations": {
        "en": {
