    "For power users; one option=value per line. Applied on top of VortX's defaults the next time a video starts.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per utenti esperti; una opzione=valore per riga. Applicata sopra le impostazioni predefinite di VortX al successivo avvio di un video."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para usuarios avanzados; una opción=valor por línea. Se aplica sobre los valores predeterminados de VortX la próxima vez que empiece un vídeo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour les utilisateurs avancés ; une option=valeur par ligne. Appliqué par-dessus les réglages par défaut de VortX au prochain démarrage d'une vidéo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für fortgeschrittene Nutzer; eine Option=Wert pro Zeile. Wird beim nächsten Videostart zusätzlich zu den Standardwerten von VortX angewendet."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para usuários avançados; uma opção=valor por linha. Aplicada sobre os padrões da VortX na próxima vez que um vídeo iniciar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "上級者向け。1 行に 1 つ option=value を記述します。次回動画開始時に VortX のデフォルト設定に上書き適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고급 사용자용. 한 줄에 option=value 하나씩 입력합니다. 다음 동영상 시작 시 VortX 기본값 위에 적용됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "面向高级用户；每行一个 option=value。下次视频开始播放时会在 VortX 的默认设置之上应用。"
          }
        }
      }
    },
