    "%@ can only be edited from that profile": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ può essere modificato solo da quel profilo"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ solo puede editarse desde ese perfil"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ne peut être modifié que depuis ce profil"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ kann nur über dieses Profil bearbeitet werden"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ só pode ser editado por aquele perfil"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ はそのプロファイルからのみ編集できます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@은(는) 해당 프로필에서만 편집할 수 있습니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 只能从该配置文件中编辑"
          }
        }
      }
    },
    "%@ other add-on%@ returned no sources for this title.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ other add-on%2$@ returned no sources for this title."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ altro componente aggiuntivo%@ non ha restituito sorgenti per questo titolo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ otro complemento%@ no devolvió fuentes para este título."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ autre add-on%@ n'a renvoyé aucune source pour ce titre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ weitere Add-on%@ haben für diesen Titel keine Quellen geliefert."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ outro complemento%@ não retornou fontes para este título."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他の %@ 個のアドオン%@ は、このタイトルのソースを返しませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 부가 기능 %@개%@에서 이 작품에 대한 소스를 찾지 못했습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 个其他附加组件%@ 未返回此影片的任何来源。"
          }
        }
      }
    },
