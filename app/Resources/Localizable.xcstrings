    },
    "Switch to %@ to use it and edit its settings.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passa a %@ per usarlo e modificarne le impostazioni."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia a %@ para usarlo y editar sus ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Basculez vers %@ pour l'utiliser et modifier ses réglages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechsle zu %@, um es zu verwenden und seine Einstellungen zu bearbeiten."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mude para %@ para usá-lo e editar suas configurações."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ に切り替えて使用し、その設定を編集します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@(으)로 전환하여 사용하고 설정을 편집하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换到 %@ 以使用它并编辑其设置。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переключитесь на %@, чтобы использовать его и изменить его настройки."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसका उपयोग करने और इसकी सेटिंग्स संपादित करने के लिए %@ पर स्विच करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدّل إلى %@ لاستخدامه وتعديل إعداداته."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanmak ve ayarlarını düzenlemek için %@ profiline geçin."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Mude para %@ para o usar e editar as suas definições."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel over naar %@ om het te gebruiken en de instellingen ervan te bewerken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przełącz na %@, aby go używać i edytować jego ustawienia."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Byt till %@ för att använda den och redigera dess inställningar."
          }
        }
      }
    },
    "That link is not responding right now. Try a different source.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo link non risponde al momento. Prova una sorgente diversa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ese enlace no responde en este momento. Prueba una fuente diferente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce lien ne répond pas pour le moment. Essayez une autre source."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Link antwortet gerade nicht. Probiere eine andere Quelle."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esse link não está respondendo agora. Tente outra fonte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのリンクは現在応答していません。別のソースを試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해당 링크가 지금 응답하지 않습니다. 다른 소스를 시도해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该链接当前没有响应。请尝试其他来源。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта ссылка сейчас не отвечает. Попробуйте другой источник."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह लिंक अभी प्रतिक्रिया नहीं दे रहा। कोई अलग स्रोत आज़माएँ।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الرابط لا يستجيب الآن. جرّب مصدرًا مختلفًا."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu bağlantı şu anda yanıt vermiyor. Farklı bir kaynak deneyin."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa ligação não está a responder neste momento. Experimente uma fonte diferente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Die link reageert op dit moment niet. Probeer een andere bron."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten link w tej chwili nie odpowiada. Wypróbuj inne źródło."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den länken svarar inte just nu. Prova en annan källa."
          }
        }
      }
    },
    "That subtitle source did not respond in time. Try another one.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa sorgente di sottotitoli non ha risposto in tempo. Provane un'altra."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa fuente de subtítulos no respondió a tiempo. Prueba con otra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette source de sous-titres n'a pas répondu à temps. Essayez-en une autre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Untertitelquelle hat nicht rechtzeitig geantwortet. Probiere eine andere."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa fonte de legendas não respondeu a tempo. Tente outra."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その字幕ソースは時間内に応答しませんでした。別のものを試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해당 자막 소스가 제때 응답하지 않았습니다. 다른 것을 시도해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该字幕来源未能及时响应。请尝试另一个。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот источник субтитров не ответил вовремя. Попробуйте другой."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह सबटाइटल स्रोत समय पर प्रतिक्रिया नहीं दे सका। कोई और आज़माएँ।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يستجب مصدر الترجمة ذاك في الوقت المناسب. جرّب آخر."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu altyazı kaynağı zamanında yanıt vermedi. Başka bir tane deneyin."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa fonte de legendas não respondeu a tempo. Experimente outra."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Die ondertitelbron reageerde niet op tijd. Probeer een andere."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To źródło napisów nie odpowiedziało na czas. Wypróbuj inne."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den undertextkällan svarade inte i tid. Prova en annan."
          }
        }
      }
    },
    "The app quits immediately. Open it again from the Home Screen; the streaming server restarts with it.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app si chiude immediatamente. Riaprila dalla schermata Home; il server di streaming si riavvia con essa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app se cierra de inmediato. Vuelve a abrirla desde la pantalla de inicio; el servidor de streaming se reinicia con ella."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app se ferme immédiatement. Rouvrez-la depuis l'écran d'accueil ; le serveur de streaming redémarre avec elle."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App wird sofort beendet. Öffne sie erneut über den Home-Bildschirm; der Streaming-Server startet mit ihr neu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O app fecha imediatamente. Abra-o novamente pela Tela de Início; o servidor de streaming reinicia junto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリはすぐに終了します。ホーム画面から再度開いてください。ストリーミングサーバーも一緒に再起動します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱이 즉시 종료됩니다. 홈 화면에서 다시 여세요. 스트리밍 서버도 함께 다시 시작됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用会立即退出。请从主屏幕再次打开它；流媒体服务器会随之重启。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложение немедленно закрывается. Откройте его снова с главного экрана; сервер потоковой передачи запустится вместе с ним."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप तुरंत बंद हो जाता है। उसे Home Screen से फिर से खोलें; स्ट्रीमिंग सर्वर उसके साथ पुनः आरंभ होता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُغلَق التطبيق فورًا. افتحه مجددًا من الشاشة الرئيسية؛ يُعاد تشغيل خادم البث معه."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulama hemen kapanır. Ana Ekran'dan tekrar açın; akış sunucusu onunla birlikte yeniden başlar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A app encerra de imediato. Abra-a novamente a partir do ecrã principal; o servidor de streaming reinicia com ela."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De app sluit meteen af. Open hem opnieuw vanaf het beginscherm; de streamingserver start mee opnieuw op."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikacja natychmiast się zamknie. Otwórz ją ponownie z ekranu głównego; serwer strumieniowania uruchomi się razem z nią."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen avslutas omedelbart. Öppna den igen från hemskärmen; strömningsservern startas om med den."
          }
        }
      }
    },
    "The main profile. It uses your Stremio account's own watch history, like before profiles existed.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il profilo principale. Usa la cronologia di visione del tuo account Stremio, come prima che esistessero i profili."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El perfil principal. Usa el propio historial de visualización de tu cuenta Stremio, como antes de que existieran los perfiles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le profil principal. Il utilise l'historique de visionnage propre à votre compte Stremio, comme avant l'existence des profils."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Hauptprofil. Es verwendet den eigenen Wiedergabeverlauf deines Stremio-Kontos, wie vor der Einführung von Profilen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O perfil principal. Ele usa o histórico de exibição da sua própria conta Stremio, como antes de os perfis existirem."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メインのプロファイルです。プロファイルが存在する前と同じように、Stremio アカウント独自の視聴履歴を使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 프로필입니다. 프로필이 존재하기 전과 마찬가지로 Stremio 계정 자체의 시청 기록을 사용합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主配置文件。它使用你的 Stremio 账户自己的观看历史，就像配置文件出现之前那样。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Основной профиль. Он использует собственную историю просмотра вашего аккаунта Stremio, как было до появления профилей."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मुख्य प्रोफ़ाइल। यह आपके Stremio खाते का अपना देखने का इतिहास उपयोग करती है, जैसे प्रोफ़ाइलें होने से पहले होता था।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الملف الشخصي الرئيسي. يستخدم سجل المشاهدة الخاص بحساب Stremio الخاص بك، كما كان قبل وجود الملفات الشخصية."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana profil. Profiller var olmadan önceki gibi, Stremio hesabınızın kendi izleme geçmişini kullanır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O perfil principal. Usa o histórico de visualização da sua própria conta Stremio, como antes de existirem perfis."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het hoofdprofiel. Het gebruikt de eigen kijkgeschiedenis van je Stremio-account, net zoals voordat er profielen bestonden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Główny profil. Korzysta z własnej historii oglądania Twojego konta Stremio, jak przed pojawieniem się profili."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Huvudprofilen. Den använder ditt Stremio-kontos egna tittarhistorik, som innan profiler fanns."
          }
        }
      }
    },
    "The player auto-picks these when a title starts. Forced shows only foreign-dialogue captions; Always shows full subtitles in your language. Foreign-language titles always get full subtitles so you can follow.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il lettore li seleziona automaticamente all'avvio di un titolo. Forzati mostra solo i sottotitoli dei dialoghi in lingua straniera; Sempre mostra i sottotitoli completi nella tua lingua. I titoli in lingua straniera ricevono sempre i sottotitoli completi così puoi seguirli."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El reproductor los selecciona automáticamente al empezar un título. Forzados muestra solo los subtítulos de diálogos en idioma extranjero; Siempre muestra los subtítulos completos en tu idioma. Los títulos en idioma extranjero siempre reciben subtítulos completos para que puedas seguirlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le lecteur les sélectionne automatiquement au démarrage d'un titre. Forcés affiche uniquement les sous-titres des dialogues en langue étrangère ; Toujours affiche les sous-titres complets dans votre langue. Les titres en langue étrangère reçoivent toujours des sous-titres complets pour que vous puissiez suivre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Player wählt diese automatisch aus, wenn ein Titel startet. „Erzwungen“ zeigt nur Untertitel für fremdsprachige Dialoge; „Immer“ zeigt vollständige Untertitel in deiner Sprache. Fremdsprachige Titel erhalten immer vollständige Untertitel, damit du folgen kannst."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O player escolhe estas automaticamente quando um título inicia. Forçadas mostra apenas as legendas de diálogos em outros idiomas; Sempre mostra legendas completas no seu idioma. Títulos em idioma estrangeiro sempre recebem legendas completas para você acompanhar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイトル開始時にプレーヤーがこれらを自動選択します。「強制」は外国語のセリフのキャプションのみを表示し、「常に」は使用言語のフル字幕を表示します。外国語のタイトルには、内容を追えるよう常にフル字幕が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "플레이어는 작품이 시작될 때 이를 자동으로 선택합니다. 강제는 외국어 대사 자막만 표시하고, 항상은 사용 언어로 전체 자막을 표시합니다. 외국어 작품은 따라갈 수 있도록 항상 전체 자막이 표시됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "播放器在影片开始时会自动选择这些。强制只显示外语对白字幕；始终会以你的语言显示完整字幕。外语影片始终会获得完整字幕，以便你跟上剧情。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плеер автоматически выбирает их при запуске тайтла. «Форсированные» показывают только субтитры для иностранной речи; «Всегда» показывает полные субтитры на вашем языке. Иноязычные тайтлы всегда получают полные субтитры, чтобы вы могли следить за сюжетом."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइटल शुरू होने पर प्लेयर इन्हें स्वतः चुन लेता है। बाध्य केवल विदेशी-संवाद के कैप्शन दिखाता है; हमेशा आपकी भाषा में पूरे सबटाइटल दिखाता है। विदेशी-भाषा वाले टाइटल को हमेशा पूरे सबटाइटल मिलते हैं ताकि आप समझ सकें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يختار المشغّل هذه تلقائيًا عند بدء عنوان. يعرض الوضع المفروض تعليقات الحوار الأجنبي فقط؛ ويعرض الوضع الدائم الترجمة الكاملة بلغتك. تحصل العناوين الأجنبية اللغة دائمًا على ترجمة كاملة لتتمكن من المتابعة."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir başlık başladığında oynatıcı bunları otomatik seçer. Zorunlu yalnızca yabancı diyalog altyazılarını gösterir; Her Zaman ise kendi dilinizde tam altyazıları gösterir. Yabancı dildeki başlıklar takip edebilmeniz için her zaman tam altyazı alır."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O leitor escolhe estas automaticamente quando um título começa. Forçadas mostra apenas as legendas de diálogos em língua estrangeira; Sempre mostra legendas completas no seu idioma. Os títulos em língua estrangeira recebem sempre legendas completas para que possa acompanhar."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De speler kiest deze automatisch wanneer een titel start. Geforceerd toont alleen ondertitels voor vreemdtalige dialogen; Altijd toont volledige ondertiteling in jouw taal. Vreemdtalige titels krijgen altijd volledige ondertiteling zodat je het kunt volgen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odtwarzacz dobiera je automatycznie po uruchomieniu tytułu. Wymuszone pokazuje tylko napisy do obcojęzycznych dialogów; Zawsze pokazuje pełne napisy w Twoim języku. Tytuły obcojęzyczne zawsze otrzymują pełne napisy, abyś mógł śledzić akcję."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spelaren väljer dessa automatiskt när en titel startar. Forcerade visar bara undertexter för främmande dialog; Alltid visar fullständiga undertexter på ditt språk. Titlar på främmande språk får alltid fullständiga undertexter så att du kan följa med."
          }
        }
      }
    },
    "This account's profiles differ from this device. Merge both to keep every profile (recommended), or force one side.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I profili di questo account differiscono da quelli di questo dispositivo. Unisci entrambi per mantenere ogni profilo (consigliato), oppure forza un lato."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los perfiles de esta cuenta difieren de los de este dispositivo. Fusiona ambos para conservar todos los perfiles (recomendado), o fuerza un lado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les profils de ce compte diffèrent de ceux de cet appareil. Fusionnez les deux pour conserver tous les profils (recommandé), ou forcez un côté."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Profile dieses Kontos unterscheiden sich von diesem Gerät. Führe beide zusammen, um jedes Profil zu behalten (empfohlen), oder erzwinge eine Seite."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os perfis desta conta diferem dos deste dispositivo. Mescle os dois para manter todos os perfis (recomendado) ou force um dos lados."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアカウントのプロファイルは、このデバイスと異なります。両方をマージしてすべてのプロファイルを保持する（推奨）か、いずれか一方を強制してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 계정의 프로필이 이 기기와 다릅니다. 모든 프로필을 유지하려면 양쪽을 병합하거나(권장), 한쪽을 강제 적용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此账户的配置文件与本设备不同。合并双方以保留每个配置文件（推荐），或强制采用一方。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Профили этого аккаунта отличаются от профилей на этом устройстве. Объедините оба, чтобы сохранить все профили (рекомендуется), или принудительно выберите одну сторону."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस खाते की प्रोफ़ाइलें इस डिवाइस से भिन्न हैं। हर प्रोफ़ाइल रखने के लिए दोनों को मर्ज करें (अनुशंसित), या किसी एक पक्ष को बाध्य करें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تختلف الملفات الشخصية لهذا الحساب عن هذا الجهاز. ادمج الجانبين للاحتفاظ بكل ملف شخصي (مُوصى به)، أو افرض جانبًا واحدًا."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu hesabın profilleri bu cihazdakinden farklı. Her profili korumak için ikisini birleştirin (önerilir) veya bir tarafı zorlayın."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os perfis desta conta diferem dos deste dispositivo. Junte ambos para manter todos os perfis (recomendado) ou force um dos lados."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De profielen van dit account verschillen van dit apparaat. Voeg beide samen om elk profiel te behouden (aanbevolen), of forceer één kant."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Profile na tym koncie różnią się od tych na tym urządzeniu. Scal oba, aby zachować każdy profil (zalecane), lub wymuś jedną stronę."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det här kontots profiler skiljer sig från den här enheten. Slå ihop båda för att behålla alla profiler (rekommenderas), eller tvinga fram en sida."
          }
        }
      }
    },
    "This is shown only once. It is the only way back in if you forget your password and lose your devices. Store it somewhere safe.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Viene mostrato una sola volta. È l'unico modo per rientrare se dimentichi la password e perdi i tuoi dispositivi. Conservalo in un luogo sicuro."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto se muestra una sola vez. Es la única forma de volver a entrar si olvidas tu contraseña y pierdes tus dispositivos. Guárdalo en un lugar seguro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci n'est affiché qu'une seule fois. C'est le seul moyen de revenir si vous oubliez votre mot de passe et perdez vos appareils. Conservez-le en lieu sûr."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies wird nur einmal angezeigt. Es ist der einzige Weg zurück, falls du dein Passwort vergisst und deine Geräte verlierst. Bewahre es an einem sicheren Ort auf."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto é exibido apenas uma vez. É a única forma de voltar a entrar caso esqueça sua senha e perca seus dispositivos. Guarde-o em um lugar seguro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは一度だけ表示されます。パスワードを忘れてデバイスを失った場合に戻る唯一の方法です。安全な場所に保管してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 코드는 한 번만 표시됩니다. 비밀번호를 잊고 기기를 잃었을 때 다시 들어올 수 있는 유일한 방법입니다. 안전한 곳에 보관하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此内容仅显示一次。这是你忘记密码并丢失设备后唯一的找回方式。请将其存放在安全的地方。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это показывается только один раз. Это единственный способ вернуться, если вы забудете пароль и потеряете устройства. Храните его в надёжном месте."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह केवल एक बार दिखाया जाता है। यदि आप अपना पासवर्ड भूल जाते हैं और अपने डिवाइस खो देते हैं तो वापस आने का यही एकमात्र रास्ता है। इसे कहीं सुरक्षित रखें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُعرَض هذا مرة واحدة فقط. إنه الطريقة الوحيدة للعودة إذا نسيت كلمة المرور وفقدت أجهزتك. خزّنه في مكان آمن."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu yalnızca bir kez gösterilir. Parolanızı unutur ve cihazlarınızı kaybederseniz geri dönmenin tek yolu budur. Güvenli bir yerde saklayın."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto é mostrado apenas uma vez. É a única forma de voltar a entrar se esquecer a palavra-passe e perder os dispositivos. Guarde-o num local seguro."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit wordt maar één keer getoond. Het is de enige manier om weer binnen te komen als je je wachtwoord vergeet en je apparaten kwijtraakt. Bewaar het op een veilige plek."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To jest pokazane tylko raz. To jedyny sposób na odzyskanie dostępu, jeśli zapomnisz hasła i utracisz urządzenia. Przechowuj go w bezpiecznym miejscu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta visas bara en gång. Det är enda sättet tillbaka in om du glömmer ditt lösenord och förlorar dina enheter. Förvara det på en säker plats."
          }
        }
      }
    },
    "This magnet has %@ videos. Choose which one to play.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo magnet contiene %@ video. Scegli quale riprodurre."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este magnet tiene %@ vídeos. Elige cuál reproducir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce magnet contient %@ vidéos. Choisissez celle à lire."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Magnet enthält %@ Videos. Wähle, welches abgespielt werden soll."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este magnet tem %@ vídeos. Escolha qual reproduzir."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この magnet には %@ 本の動画があります。再生する動画を選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 magnet에는 동영상 %@개가 있습니다. 재생할 항목을 선택하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此磁力链接包含 %@ 个视频。请选择要播放的一个。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В этом magnet %@ видео. Выберите, какое воспроизвести."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस magnet में %@ वीडियो हैं। चुनें कि कौन सा चलाना है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتوي هذا الـ magnet على %@ مقطع فيديو. اختر أيها تريد تشغيله."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu magnet %@ video içeriyor. Hangisinin oynatılacağını seçin."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Este magnet tem %@ vídeos. Escolha qual reproduzir."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze magnet bevat %@ video's. Kies welke je wilt afspelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten magnet ma %@ filmów. Wybierz, który odtworzyć."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den här magnetlänken har %@ videor. Välj vilken som ska spelas upp."
          }
        }
      }
    },
