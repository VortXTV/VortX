    "Styles the built-in player's subtitles. Pick which subtitle track to show from the player while watching.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Definisce lo stile dei sottotitoli del lettore integrato. Scegli quale traccia di sottotitoli mostrare dal lettore durante la visione."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Da estilo a los subtítulos del reproductor integrado. Elige qué pista de subtítulos mostrar desde el reproductor mientras ves algo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Met en forme les sous-titres du lecteur intégré. Choisissez la piste de sous-titres à afficher depuis le lecteur pendant le visionnage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestaltet die Untertitel des integrierten Players. Wähle während des Schauens im Player, welche Untertitelspur angezeigt wird."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estiliza as legendas do player integrado. Escolha qual faixa de legenda exibir a partir do player enquanto assiste."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "内蔵プレーヤーの字幕のスタイルを設定します。視聴中にプレーヤーから表示する字幕トラックを選択できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내장 플레이어의 자막 스타일을 지정합니다. 시청 중 플레이어에서 표시할 자막 트랙을 선택하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为内置播放器的字幕设置样式。在观看时从播放器中选择要显示的字幕轨道。"
          }
        }
      }
    },
    "Subtitle Style": {
      "localizations": {
