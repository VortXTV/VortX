            "value": "Búsquedas recientes"
          }
        }
      }
    },
    "Reduced": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ridotta"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reducido"
          }
        }
      }
    },
    "Require words": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Parole obbligatorie"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Palabras obligatorias"
          }
        }
      }
    },
    "S%@ · E%@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "S%1$@ · E%2$@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "S%@ · E%@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "T%@ · E%@"
          }
        }
      }
    },
    "Safety filter hides CAM and fake-quality sources. Hide / Require words filter the source list by name, comma-separated (e.g. hide \"cam, ts\", require \"remux\").": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il filtro di sicurezza nasconde le sorgenti CAM e di falsa qualità. Le parole da nascondere / obbligatorie filtrano l'elenco delle sorgenti per nome, separate da virgola (es. nascondi «cam, ts», richiedi «remux»)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El filtro de seguridad oculta las fuentes CAM y de calidad falsa. Las palabras a ocultar / obligatorias filtran la lista de fuentes por nombre, separadas por comas (p. ej. ocultar «cam, ts», requerir «remux»)."
          }
        }
      }
    },
    "Save & Use": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva e usa"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guardar y usar"
          }
        }
      }
    },
    "Save your profiles, theme, and playback preferences to a file you can keep, so a future major update can never lose them. Export Library carries the active profile's saved titles and watch progress to another device or profile, no account needed.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva i tuoi profili, il tema e le preferenze di riproduzione in un file da conservare, così un futuro aggiornamento importante non potrà mai perderli. Esporta libreria porta i titoli salvati e l'avanzamento del profilo attivo su un altro dispositivo o profilo, senza bisogno di un account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda tus perfiles, el tema y las preferencias de reproducción en un archivo que puedes conservar, para que una futura actualización importante nunca los pierda. Exportar biblioteca lleva los títulos guardados y el progreso del perfil activo a otro dispositivo o perfil, sin necesidad de cuenta."
          }
        }
      }
    },
    "Save your recovery code": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva il tuo codice di recupero"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda tu código de recuperación"
          }
        }
      }
    },
    "Saved": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvato"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guardado"
          }
        }
      }
    },
    "Scan with your phone to open this stream there  ·  Press Back to dismiss": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scansiona col telefono per aprire questa sorgente lì  ·  Premi Indietro per chiudere"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanea con tu móvil para abrir esta fuente allí  ·  Pulsa Atrás para descartar"
          }
        }
      }
    },
    "Seek bar style": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Stile barra di avanzamento"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estilo de la barra de progreso"
          }
        }
      }
    },
    "Select = choose another source    ·    Play/Pause = retry    ·    Menu = back": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = scegli un'altra sorgente    ·    Play/Pausa = riprova    ·    Menu = indietro"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Select = elegir otra fuente    ·    Reproducir/Pausa = reintentar    ·    Menú = atrás"
          }
        }
      }
    },
    "Select a profile to edit it. Each profile keeps its own look, languages, PIN, and optionally its own Stremio account. A profile with a PIN asks for it before it can be edited.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona un profilo per modificarlo. Ogni profilo mantiene il proprio aspetto, le lingue, il PIN e, facoltativamente, il proprio account Stremio. Un profilo con PIN lo richiede prima di poter essere modificato."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona un perfil para editarlo. Cada perfil mantiene su propio aspecto, idiomas, PIN y, opcionalmente, su propia cuenta Stremio. Un perfil con PIN lo pide antes de poder editarse."
          }
        }
      }
    },
    "Settings": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impostazioni"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustes"
          }
        }
      }
    },
    "Sideload the new IPA from the GitHub releases page, your sign-in and settings carry over.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installa tramite sideload il nuovo IPA dalla pagina delle release di GitHub; il tuo accesso e le impostazioni vengono mantenuti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala mediante sideload el nuevo IPA desde la página de releases de GitHub; tu inicio de sesión y ajustes se conservan."
          }
        }
      }
    },
    "Signing in pulls your add-ons and library into the app. Your account stays on this device.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accedendo, i tuoi componenti aggiuntivi e la libreria vengono caricati nell'app. Il tuo account resta su questo dispositivo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al iniciar sesión, tus complementos y tu biblioteca se cargan en la app. Tu cuenta permanece en este dispositivo."
          }
        }
      }
    },
    "Sort": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ordina"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ordenar"
          }
        }
      }
    },
    "Source failed, trying another…  (%@/%@)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Source failed, trying another…  (%1$@/%2$@)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sorgente non riuscita, ne provo un'altra…  (%@/%@)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fuente fallida, probando otra…  (%@/%@)"
          }
        }
      }
    },
    "Source type priority": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Priorità tipo di sorgente"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prioridad de tipo de fuente"
          }
        }
      }
    },
    "Sources matching the top type are ranked first within each quality tier. Debrid and Usenet are always instant; Torrent streams require peer availability.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sorgenti del tipo in cima vengono classificate per prime in ogni fascia di qualità. Debrid e Usenet sono sempre istantanei; le sorgenti Torrent richiedono la disponibilità di peer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fuentes del tipo superior se clasifican primero dentro de cada nivel de calidad. Debrid y Usenet son siempre instantáneos; las fuentes Torrent requieren disponibilidad de peers."
          }
        }
      }
    },
    "Still finding more · %@/%@ add-ons": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Still finding more · %1$@/%2$@ add-ons"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricerca ancora in corso · %@/%@ componenti aggiuntivi"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscando más · %@/%@ complementos"
          }
        }
      }
    },
    "Streaming Server": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Server di streaming"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Servidor de streaming"
          }
        }
      }
    },
    "Streams": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Streams"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Streams"
          }
        }
      }
    },
    "Stremio · %@ add-ons · %@ stream sources": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Stremio · %1$@ add-ons · %2$@ stream sources"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Stremio · %@ componenti aggiuntivi · %@ sorgenti di streaming"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Stremio · %@ complementos · %@ fuentes de streaming"
          }
        }
      }
    },
    "Strict": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rigoroso"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estricto"
          }
        }
      }
    },
    "Styles the built-in player's subtitles. Pick which subtitle track to show from the player while watching.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Definisce lo stile dei sottotitoli del lettore integrato. Scegli quale traccia di sottotitoli mostrare dal lettore durante la visione."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Da estilo a los subtítulos del reproductor integrado. Elige qué pista de subtítulos mostrar desde el reproductor mientras ves algo."
          }
        }
      }
    },
    "Subtitle Style": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Stile sottotitoli"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estilo de subtítulos"
          }
        }
      }
    },
    "Switch to %@ to use it and edit its settings.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passa a %@ per usarlo e modificarne le impostazioni."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia a %@ para usarlo y editar sus ajustes."
          }
        }
      }
    },
    "That link is not responding right now. Try a different source.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo link non risponde al momento. Prova una sorgente diversa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ese enlace no responde en este momento. Prueba una fuente diferente."
          }
        }
      }
    },
    "That subtitle source did not respond in time. Try another one.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa sorgente di sottotitoli non ha risposto in tempo. Provane un'altra."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa fuente de subtítulos no respondió a tiempo. Prueba con otra."
          }
        }
      }
    },
    "The app quits immediately. Open it again from the Home Screen; the streaming server restarts with it.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app si chiude immediatamente. Riaprila dalla schermata Home; il server di streaming si riavvia con essa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app se cierra de inmediato. Vuelve a abrirla desde la pantalla de inicio; el servidor de streaming se reinicia con ella."
          }
        }
      }
    },
    "The main profile. It uses your Stremio account's own watch history, like before profiles existed.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il profilo principale. Usa la cronologia di visione del tuo account Stremio, come prima che esistessero i profili."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El perfil principal. Usa el propio historial de visualización de tu cuenta Stremio, como antes de que existieran los perfiles."
          }
        }
      }
    },
    "The player auto-picks these when a title starts. Forced shows only foreign-dialogue captions; Always shows full subtitles in your language. Foreign-language titles always get full subtitles so you can follow.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il lettore li seleziona automaticamente all'avvio di un titolo. Forzati mostra solo i sottotitoli dei dialoghi in lingua straniera; Sempre mostra i sottotitoli completi nella tua lingua. I titoli in lingua straniera ricevono sempre i sottotitoli completi così puoi seguirli."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El reproductor los selecciona automáticamente al empezar un título. Forzados muestra solo los subtítulos de diálogos en idioma extranjero; Siempre muestra los subtítulos completos en tu idioma. Los títulos en idioma extranjero siempre reciben subtítulos completos para que puedas seguirlos."
          }
        }
      }
    },
    "This account's profiles differ from this device. Merge both to keep every profile (recommended), or force one side.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I profili di questo account differiscono da quelli di questo dispositivo. Unisci entrambi per mantenere ogni profilo (consigliato), oppure forza un lato."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los perfiles de esta cuenta difieren de los de este dispositivo. Fusiona ambos para conservar todos los perfiles (recomendado), o fuerza un lado."
          }
        }
      }
    },
    "This is shown only once. It is the only way back in if you forget your password and lose your devices. Store it somewhere safe.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Viene mostrato una sola volta. È l'unico modo per rientrare se dimentichi la password e perdi i tuoi dispositivi. Conservalo in un luogo sicuro."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto se muestra una sola vez. Es la única forma de volver a entrar si olvidas tu contraseña y pierdes tus dispositivos. Guárdalo en un lugar seguro."
          }
        }
      }
    },
    "This magnet has %@ videos. Choose which one to play.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo magnet contiene %@ video. Scegli quale riprodurre."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este magnet tiene %@ vídeos. Elige cuál reproducir."
          }
        }
      }
    },
    "Tone-map to SDR": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Converti in SDR"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Convertir a SDR"
          }
        }
      }
    },
    "Unlimited": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Illimitato"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilimitado"
          }
        }
      }
    },
    "UP NEXT": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "PROSSIMO"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A CONTINUACIÓN"
          }
        }
      }
    },
    "Update available": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiornamento disponibile"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualización disponible"
          }
        }
      }
    },
    "Use add-on ranking order": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa l'ordine di classificazione dei componenti aggiuntivi"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usar el orden de clasificación de los complementos"
          }
        }
      }
    },
    "Use Embedded": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa integrato"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usar integrado"
          }
        }
      }
    },
    "Use the server embedded on this device, or point VortX at a remote / dedicated Stremio server (for example one you run at home).": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il server integrato in questo dispositivo, oppure punta VortX a un server Stremio remoto / dedicato (ad esempio uno che gestisci a casa)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el servidor integrado en este dispositivo, o apunta VortX a un servidor Stremio remoto / dedicado (por ejemplo uno que ejecutes en casa)."
          }
        }
      }
    },
    "Vort": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vort"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vort"
          }
        }
      }
    },
    "VortX %@": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "VortX %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "VortX %@"
          }
        }
      }
    },
    "VortX account": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Account VortX"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuenta VortX"
          }
        }
      }
    },
    "Warm": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Caldo"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cálido"
          }
        }
      }
    },
    "Watch Credits": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda i titoli di coda"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver los créditos"
          }
        }
      }
    },
    "What's new": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Novità"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Novedades"
          }
        }
      }
    },
    "When on, streams appear in the order your add-ons return them. Useful if you use a ranking add-on like AIOStreams. When off, the app's own ranking applies.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando è attivo, le sorgenti appaiono nell'ordine in cui i tuoi componenti aggiuntivi le restituiscono. Utile se usi un componente di classificazione come AIOStreams. Quando è disattivo, si applica la classificazione dell'app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, las fuentes aparecen en el orden en que las devuelven tus complementos. Útil si usas un complemento de clasificación como AIOStreams. Cuando está desactivado, se aplica la clasificación de la app."
          }
        }
      }
    },
    "Where to Watch": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dove guardare"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dónde ver"
          }
        }
      }
    },
    "Who's watching?": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chi sta guardando?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Quién está viendo?"
          }
        }
      }
    },
    "Wrong PIN": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "PIN errato"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PIN incorrecto"
          }
        }
      }
    },
    "XRDB (extendedratings.com) bakes ratings from up to 12 sources, quality badges, and streaming-provider logos onto your posters and backdrops. Run your own XRDB instance or use a hosted one, set its address and your profile alias, and VortX loads its artwork everywhere. Optional, and unrelated to debrid.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "XRDB (extendedratings.com) integra valutazioni da un massimo di 12 fonti, badge di qualità e loghi dei provider di streaming sui tuoi poster e sfondi. Usa una tua istanza XRDB o una ospitata, imposta il suo indirizzo e il tuo alias profilo, e VortX carica le sue immagini ovunque. Facoltativo e non collegato al debrid."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "XRDB (extendedratings.com) integra valoraciones de hasta 12 fuentes, insignias de calidad y logotipos de proveedores de streaming en tus pósteres y fondos. Usa tu propia instancia XRDB o una alojada, configura su dirección y tu alias de perfil, y VortX carga sus imágenes en todas partes. Opcional y sin relación con debrid."
          }
        }
      }
    },
    "Your profiles, settings, and metadata keys sync to this account, end-to-end encrypted. They also sync automatically a moment after any change.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi profili, le impostazioni e le chiavi dei metadati si sincronizzano con questo account, cifrati end-to-end. Si sincronizzano anche automaticamente subito dopo ogni modifica."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus perfiles, ajustes y claves de metadatos se sincronizan con esta cuenta, cifrados de extremo a extremo. También se sincronizan automáticamente un momento después de cualquier cambio."
          }
        }
      }
    }
  },
  "version": "1.0"
}