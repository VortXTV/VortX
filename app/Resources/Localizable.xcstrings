    },
    "Install the new build from the GitHub releases page; your sign-in and settings carry over.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installa la nuova versione dalla pagina delle release di GitHub; il tuo accesso e le impostazioni vengono mantenuti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala la nueva versión desde la página de releases de GitHub; tu inicio de sesión y ajustes se conservan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez la nouvelle version depuis la page des releases GitHub ; votre connexion et vos réglages sont conservés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installiere den neuen Build von der GitHub-Releases-Seite; deine Anmeldung und Einstellungen werden übernommen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale a nova versão pela página de releases do GitHub; seu login e configurações são mantidos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub のリリースページから新しいビルドをインストールしてください。サインインと設定は引き継がれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub 릴리스 페이지에서 새 빌드를 설치하세요. 로그인과 설정은 그대로 유지됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 GitHub 发布页安装新构建版本；你的登录和设置会随之保留。"
          }
        }
      }
    },
    "Keeps its own watch history, synced through your Stremio account to your other devices.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene la propria cronologia di visione, sincronizzata tramite il tuo account Stremio sugli altri dispositivi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene su propio historial de visualización, sincronizado a través de tu cuenta Stremio en tus otros dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserve son propre historique de visionnage, synchronisé via votre compte Stremio vers vos autres appareils."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behält einen eigenen Wiedergabeverlauf, der über dein Stremio-Konto mit deinen anderen Geräten synchronisiert wird."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém o próprio histórico de exibição, sincronizado pela sua conta Stremio com os seus outros dispositivos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "独自の視聴履歴を保持し、Stremio アカウントを通じて他のデバイスに同期します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자체 시청 기록을 유지하며, Stremio 계정을 통해 다른 기기와 동기화됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保留它自己的观看历史，通过你的 Stremio 账户同步到你的其他设备。"
          }
        }
      }
    },
