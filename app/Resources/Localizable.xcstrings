          }
        }
      }
    },
    "Built-in player": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lettore integrato"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproductor integrado"
          }
        }
      }
    },
    "Check Add-ons for one that lists \"Streams\" (not just Catalogs or Metadata). If you recently force-quit the app, reopen it so your add-ons reload, or re-add a stream add-on.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controlla nei Componenti aggiuntivi se ce n'è uno che elenca «Streams» (non solo Cataloghi o Metadati). Se hai chiuso forzatamente l'app di recente, riaprila così i componenti aggiuntivi si ricaricano, oppure aggiungi di nuovo un componente per le sorgenti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca en Complementos uno que incluya «Streams» (no solo Catálogos o Metadatos). Si cerraste la app a la fuerza hace poco, vuelve a abrirla para que tus complementos se recarguen, o vuelve a añadir un complemento de fuentes."
          }
        }
      }
    },
    "Choose which rows appear on Home and the order they show in.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli quali righe appaiono nella Home e in quale ordine."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige qué filas aparecen en Inicio y en qué orden."
          }
        }
      }
    },
    "Could not build a code for this link.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile generare un codice per questo link."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo generar un código para este enlace."
          }
        }
      }
    },
