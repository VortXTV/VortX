            "value": "Priorité du type de source"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Priorität der Quelltypen"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prioridade do tipo de fonte"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ソースタイプの優先順位"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "소스 유형 우선순위"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "来源类型优先级"
          }
        }
      }
    },
    "Sources matching the top type are ranked first within each quality tier. Debrid and Usenet are always instant; Torrent streams require peer availability.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sorgenti del tipo in cima vengono classificate per prime in ogni fascia di qualità. Debrid e Usenet sono sempre istantanei; le sorgenti Torrent richiedono la disponibilità di peer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fuentes del tipo superior se clasifican primero dentro de cada nivel de calidad. Debrid y Usenet son siempre instantáneos; las fuentes Torrent requieren disponibilidad de peers."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les sources correspondant au type prioritaire sont classées en premier au sein de chaque palier de qualité. Debrid et Usenet sont toujours instantanés ; les streams Torrent nécessitent la disponibilité de pairs."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Quellen, die zum obersten Typ passen, werden innerhalb jeder Qualitätsstufe zuerst gereiht. debrid und Usenet sind immer sofort verfügbar; Torrent-Streams erfordern verfügbare Peers."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As fontes que correspondem ao tipo do topo são classificadas primeiro dentro de cada faixa de qualidade. Debrid e Usenet são sempre instantâneos; streams via Torrent dependem da disponibilidade de peers."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "上位のタイプに一致するソースが、各画質ティア内で最初にランク付けされます。debrid と Usenet は常に瞬時です。torrent ストリームにはピアの利用可能性が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상위 유형과 일치하는 소스가 각 화질 단계 내에서 먼저 순위가 매겨집니다. debrid와 Usenet은 항상 즉시 재생되며, Torrent 스트림은 피어 가용성이 필요합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "匹配最高类型的来源会在各画质层级内优先排序。debrid 和 Usenet 始终即时；torrent 串流需要有可用的 peer。"
          }
        }
      }
    },
