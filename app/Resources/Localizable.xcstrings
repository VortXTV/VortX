    "Customize catalogs": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalizza i cataloghi"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Personalizar catálogos"
          }
        }
      }
    },
    "Debrid services": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Servizi debrid"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Servicios debrid"
          }
        }
      }
    },
    "Direct and debrid streams open in your chosen player automatically. Torrents and the built-in player are unaffected.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sorgenti dirette e debrid si aprono automaticamente nel lettore scelto. Torrent e lettore integrato non sono interessati."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fuentes directas y debrid se abren automáticamente en el reproductor elegido. Los torrents y el reproductor integrado no se ven afectados."
          }
        }
      }
    },
    "Direct and debrid streams open straight in your chosen player, which then handles playback and resume. Torrents, header-protected sources, and trailers always use the built-in player.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le sorgenti dirette e debrid si aprono direttamente nel lettore scelto, che poi gestisce riproduzione e ripresa. Torrent, sorgenti protette da header e trailer usano sempre il lettore integrato."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fuentes directas y debrid se abren directamente en el reproductor elegido, que luego gestiona la reproducción y la reanudación. Los torrents, las fuentes protegidas por cabeceras y los tráileres siempre usan el reproductor integrado."
          }
        }
      }
    },
    "Direct Links Only": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo link diretti"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo enlaces directos"
          }
        }
      }
    },
    "Discover": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esplora"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descubrir"
          }
        }
      }
    },
    "Enter PIN for %@": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci il PIN per %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce el PIN de %@"
          }
        }
      }
    },
    "Export Library, which saves a profile's titles and watch progress to a file, lives on iPhone, iPad, and Mac (Apple TV has no file picker). On Apple TV your library and history follow you through your VortX account.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esporta libreria, che salva i titoli e l'avanzamento di un profilo in un file, è disponibile su iPhone, iPad e Mac (Apple TV non ha un selettore file). Su Apple TV la tua libreria e la cronologia ti seguono tramite il tuo account VortX."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportar biblioteca, que guarda los títulos y el progreso de un perfil en un archivo, está disponible en iPhone, iPad y Mac (Apple TV no tiene selector de archivos). En Apple TV tu biblioteca y tu historial te acompañan a través de tu cuenta VortX."
          }
        }
      }
    },
    "Finding best…  %@/%@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Finding best…  %1$@/%2$@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricerca della migliore…  %@/%@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscando la mejor…  %@/%@"
          }
        }
      }
    },
    "Fine size  ·  %@%%": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dimensione precisa  ·  %@%%"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamaño preciso  ·  %@%%"
          }
        }
      }
    },
    "For power users; one option=value per line. Applied on top of VortX's defaults the next time a video starts.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per utenti esperti; una opzione=valore per riga. Applicata sopra le impostazioni predefinite di VortX al successivo avvio di un video."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para usuarios avanzados; una opción=valor por línea. Se aplica sobre los valores predeterminados de VortX la próxima vez que empiece un vídeo."
          }
        }
      }
    },
    "Full": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Completa"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Completa"
          }
        }
      }
    },
    "Get a notification when a new episode of a series you open is about to air. Scheduled on-device for upcoming episodes, so no background tracking is needed.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricevi una notifica quando sta per uscire un nuovo episodio di una serie che apri. Programmata sul dispositivo per gli episodi in arrivo, quindi non serve alcun tracciamento in background."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibe una notificación cuando esté a punto de emitirse un nuevo episodio de una serie que abras. Se programa en el dispositivo para los próximos episodios, así que no hace falta seguimiento en segundo plano."
          }
        }
      }
    },
    "Go to link.stremio.com and enter this code": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vai su link.stremio.com e inserisci questo codice"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve a link.stremio.com e introduce este código"
          }
        }
      }
    },
    "Got it": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ho capito"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entendido"
          }
        }
      }
    },
    "Hide words": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Parole da nascondere"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Palabras a ocultar"
          }
        }
      }
    },
    "Hides adult and CAM/fake sources from this profile. For a full lock, set a PIN on your own profile so it can't be opened from here, and hide adult add-ons under Add-ons.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nasconde le sorgenti per adulti e CAM/false da questo profilo. Per un blocco completo, imposta un PIN sul tuo profilo così non può essere aperto da qui, e nascondi i componenti aggiuntivi per adulti in Componenti aggiuntivi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta las fuentes para adultos y CAM/falsas de este perfil. Para un bloqueo completo, pon un PIN en tu propio perfil para que no se pueda abrir desde aquí, y oculta los complementos para adultos en Complementos."
          }
        }
      }
    },
    "Hides sources larger than the cap (e.g. 1080p but not a 20 GB file). Sources with no stated size are kept.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nasconde le sorgenti più grandi del limite (es. 1080p ma non un file da 20 GB). Le sorgenti senza dimensione indicata vengono mantenute."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta las fuentes mayores que el límite (p. ej. 1080p pero no un archivo de 20 GB). Las fuentes sin tamaño indicado se conservan."
          }
        }
      }
    },
    "If this title should have sources, the add-on may be offline or its config expired. Try another stream add-on.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se questo titolo dovrebbe avere sorgenti, il componente aggiuntivo potrebbe essere offline o la sua configurazione scaduta. Prova un altro componente per le sorgenti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si este título debería tener fuentes, el complemento puede estar fuera de línea o su configuración caducada. Prueba otro complemento de fuentes."
          }
        }
      }
    },
    "Import from Stremio": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa da Stremio"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importar desde Stremio"
          }
        }
      }
    },
    "Install the new build from the GitHub releases page; your sign-in and settings carry over.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Installa la nuova versione dalla pagina delle release di GitHub; il tuo accesso e le impostazioni vengono mantenuti."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala la nueva versión desde la página de releases de GitHub; tu inicio de sesión y ajustes se conservan."
          }
        }
      }
    },
    "Keeps its own watch history, synced through your Stremio account to your other devices.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene la propria cronologia di visione, sincronizzata tramite il tuo account Stremio sugli altri dispositivi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene su propio historial de visualización, sincronizado a través de tu cuenta Stremio en tus otros dispositivos."
          }
        }
      }
    },
    "Library": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Libreria"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Biblioteca"
          }
        }
      }
    },
    "LIVE": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "LIVE"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "EN VIVO"
          }
        }
      }
    },
    "Live TV": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "TV in diretta"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "TV en vivo"
          }
        }
      }
    },
    "Makes every screen's text larger or smaller. Changes apply instantly.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rende il testo di ogni schermata più grande o più piccolo. Le modifiche si applicano subito."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hace el texto de cada pantalla más grande o más pequeño. Los cambios se aplican al instante."
          }
        }
      }
    },
    "Match words as regex": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Confronta le parole come regex"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tratar las palabras como regex"
          }
        }
      }
    },
    "Metadata services": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Servizi di metadati"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Servicios de metadatos"
          }
        }
      }
    },
    "No catalogs yet. Install an add-on that provides catalogs first.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessun catalogo. Installa prima un componente aggiuntivo che fornisce cataloghi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay catálogos. Instala primero un complemento que proporcione catálogos."
          }
        }
      }
    },
    "No log yet. If the server stopped, play a torrent title to start it, then return here.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessun log. Se il server si è fermato, riproduci un titolo torrent per avviarlo, poi torna qui."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay registro. Si el servidor se detuvo, reproduce un título torrent para iniciarlo y vuelve aquí."
          }
        }
      }
    },
    "None of your %@ add-on%@ returned a playable source for this title.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "None of your %1$@ add-on%2$@ returned a playable source for this title."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuno dei tuoi %@ componente aggiuntivo%@ ha restituito una sorgente riproducibile per questo titolo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ninguno de tus %@ complemento%@ devolvió una fuente reproducible para este título."
          }
        }
      }
    },
    "Notifications": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifiche"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Notificaciones"
          }
        }
      }
    },
    "Off": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Off"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivado"
          }
        }
      }
    },
    "OK": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "OK"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "OK"
          }
        }
      }
    },
    "OLED Black": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "OLED Black"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "OLED Black"
          }
        }
      }
    },
    "On Apple TV a scan-with-your-phone backup is coming: Backup will show a QR code, you scan it with your phone, and your settings save to your VortX account. Restore shows another code to bring them right back. Until then, signing in restores your library, add-ons, and watch history here.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Su Apple TV sta arrivando un backup da scansionare col telefono: Backup mostrerà un codice QR, lo scansioni col telefono e le tue impostazioni vengono salvate nel tuo account VortX. Ripristina mostra un altro codice per riportarle indietro. Fino ad allora, accedendo ripristini qui la tua libreria, i componenti aggiuntivi e la cronologia di visione."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En Apple TV llegará pronto una copia de seguridad por escaneo con el móvil: Copia de seguridad mostrará un código QR, lo escaneas con el móvil y tus ajustes se guardan en tu cuenta VortX. Restaurar muestra otro código para traerlos de vuelta. Hasta entonces, al iniciar sesión se restauran aquí tu biblioteca, complementos e historial de visualización."
          }
        }
      }
    },
    "Open Account & sync and sign in with your Stremio account. VortX runs on the same engine, so your add-ons, library, and Continue Watching come across automatically, and stay in sync across your devices. Nothing to export or copy by hand.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri Account e sincronizzazione e accedi con il tuo account Stremio. VortX usa lo stesso motore, quindi i tuoi componenti aggiuntivi, la libreria e Continua a guardare arrivano automaticamente e restano sincronizzati su tutti i tuoi dispositivi. Niente da esportare o copiare a mano."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre Cuenta y sincronización e inicia sesión con tu cuenta Stremio. VortX usa el mismo motor, así que tus complementos, tu biblioteca y Continuar viendo llegan automáticamente y se mantienen sincronizados en todos tus dispositivos. Nada que exportar ni copiar a mano."
          }
        }
      }
    },
    "Optional. A free, end-to-end-encrypted account keeps your profiles, settings, and library safe across devices.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facoltativo. Un account gratuito e cifrato end-to-end protegge i tuoi profili, le impostazioni e la libreria su tutti i dispositivi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcional. Una cuenta gratuita y cifrada de extremo a extremo mantiene a salvo tus perfiles, ajustes y biblioteca en todos los dispositivos."
          }
        }
      }
    },
    "Optional. Add your own TMDB and MDBList keys to enrich recommendations and ratings. Nothing here is required and your keys stay on this device (and sync, encrypted, to your VortX account).": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facoltativo. Aggiungi le tue chiavi TMDB e MDBList per arricchire consigli e valutazioni. Nulla qui è obbligatorio e le tue chiavi restano su questo dispositivo (e si sincronizzano, cifrate, con il tuo account VortX)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcional. Añade tus propias claves de TMDB y MDBList para enriquecer recomendaciones y valoraciones. Nada aquí es obligatorio y tus claves permanecen en este dispositivo (y se sincronizan, cifradas, con tu cuenta VortX)."
          }
        }
      }
    },
    "Paste add-on manifest URLs, one per line, then install them all in one step.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla gli URL dei manifest dei componenti aggiuntivi, uno per riga, poi installali tutti in un solo passaggio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pega las URL de manifiesto de los complementos, una por línea, y luego instálalos todos de una vez."
          }
        }
      }
    },
    "Performance Auto keeps the full experience on capable devices and switches to a lighter one on weaker hardware. Reduced trims animations and shrinks playback buffers. Restart the app after changing this.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prestazioni Auto mantiene l'esperienza completa sui dispositivi più potenti e passa a una più leggera su hardware più debole. Ridotta riduce le animazioni e i buffer di riproduzione. Riavvia l'app dopo aver cambiato questa impostazione."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto de rendimiento mantiene la experiencia completa en dispositivos potentes y cambia a una más ligera en hardware más débil. Reducido recorta las animaciones y reduce los búferes de reproducción. Reinicia la app tras cambiar esto."
          }
        }
      }
    },
    "Pick a file": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un file"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un archivo"
          }
        }
      }
    },
    "Pick how the scrubber looks during playback. The preview shows each design.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli l'aspetto della barra di avanzamento durante la riproduzione. L'anteprima mostra ogni stile."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el aspecto de la barra de progreso durante la reproducción. La vista previa muestra cada diseño."
          }
        }
      }
    },
    "Play a link": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduci un link"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproducir un enlace"
          }
        }
      }
    },
    "Playback": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduzione"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproducción"
          }
        }
      }
    },
    "Playing in %@s": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduzione tra %@s"
          }
        },
        "es": {
