            "state": "translated",
            "value": "Preajuste de calidad"
          }
        }
      }
    },
    "Ratings on posters": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Valutazioni sui poster"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Valoraciones en los pósteres"
          }
