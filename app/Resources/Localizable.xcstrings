    "%@ · tap to get it": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · tocca per ottenerlo"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · toca para obtenerlo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · touchez pour l'obtenir"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · zum Abrufen tippen"
          }
